# ---------------------------------------------------------------------------
# Enhanced Data Structures
# ---------------------------------------------------------------------------

@dataclass
class SearchFilters:
    """Advanced filtering options for search queries."""
    date_range: Optional[Tuple[datetime, datetime]] = None
    include_domains: List[str] = field(default_factory=list)
    exclude_domains: List[str] = field(default_factory=list)
    content_types: List[str] = field(default_factory=list)  # news, images, videos, academic
    file_types: List[str] = field(default_factory=list)  # pdf, doc, ppt, etc.
    location: Optional[str] = None
    min_relevance_score: float = 0.0

@dataclass
class Entity:
    """Named entity extracted from content."""
    text: str
    label: str  # PERSON, ORG, GPE, etc.
    confidence: float

@dataclass
class ContentAnalysis:
    """AI-powered analysis of crawled content."""
    summary: str = ""
    sentiment: str = ""  # positive, negative, neutral
    entities: List[Entity] = field(default_factory=list)
    key_points: List[str] = field(default_factory=list)
    topic: str = ""
    relevance_score: float = 0.0

@dataclass
class SearchResult:
    """Enhanced search result with AI analysis."""
    position: int
    url: str
    title: str = ""
    snippet: str = ""
    content: str = ""
    error: str = ""
    source_engine: str = ""
    relevance_score: float = 0.0
    content_analysis: Optional[ContentAnalysis] = None
    crawl_timestamp: Optional[datetime] = None

# ---------------------------------------------------------------------------
# Detect available HTTP CLI tools
# ---------------------------------------------------------------------------

CURLIE_BIN = shutil.which("curlie")
WGET2_BIN  = shutil.which("wget2")
CURL_BIN   = shutil.which("curl")
WGET_BIN   = shutil.which("wget")

def _preferred_fetcher() -> str:
    """Return the name of the best available HTTP CLI tool."""
    if CURLIE_BIN:
        return "curlie"
    if WGET2_BIN:
        return "wget2"
    if CURL_BIN:
        return "curl"
    if WGET_BIN:
        return "wget"
    raise EnvironmentError(
        "No supported HTTP tool found. Install curlie, wget2, curl, or wget."
    )

# ---------------------------------------------------------------------------
# Enhanced Caching System
# ---------------------------------------------------------------------------

class SearchCache:
    """Intelligent multi-layer caching system with SQLite backend."""
    
    def __init__(self, cache_dir: str = "~/.aichat/search_cache", ttl_hours: int = 24):
        self.cache_dir = Path(cache_dir).expanduser()
        self.cache_dir.mkdir(parents=True, exist_ok=True)
        self.db_path = self.cache_dir / "search_cache.db"
        self.ttl = timedelta(hours=ttl_hours)
        self._init_db()
    
    def _init_db(self):
        """Initialize SQLite database for caching."""
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("""
                CREATE TABLE IF NOT EXISTS search_cache (
                    query_hash TEXT PRIMARY KEY,
                    query TEXT,
                    results TEXT,
                    timestamp DATETIME,
                    ttl_hours INTEGER
                )
            """)
            conn.execute("""
                CREATE TABLE IF NOT EXISTS content_cache (
                    url_hash TEXT PRIMARY KEY,
                    url TEXT,
                    content TEXT,
                    timestamp DATETIME,
                    ttl_hours INTEGER
                )
            """)
            conn.execute("""
                CREATE TABLE IF NOT EXISTS embedding_cache (
                    text_hash TEXT PRIMARY KEY,
                    embedding BLOB,
                    timestamp DATETIME
                )
            """)
    
    def _get_hash(self, text: str) -> str:
        """Generate MD5 hash for caching keys."""
        return hashlib.md5(text.encode()).hexdigest()
    
    def get_cached_results(self, query: str) -> Optional[List[Dict[str, Any]]]:
        """Retrieve cached search results if available and not expired."""
        query_hash = self._get_hash(query)
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.execute(
                "SELECT results, timestamp FROM search_cache WHERE query_hash = ?",
                (query_hash,)
            )
            row = cursor.fetchone()
            if row:
                results_json, timestamp_str = row
                timestamp = datetime.fromisoformat(timestamp_str)
                if datetime.now() - timestamp < self.ttl:
                    return json.loads(results_json)
        return None
    
    def cache_results(self, query: str, results: List[SearchResult]):
        """Cache search results with TTL."""
        query_hash = self._get_hash(query)
        results_json = json.dumps([asdict(r) for r in results])
        with sqlite3.connect(self.db_path) as conn:
            conn.execute(
                "INSERT OR REPLACE INTO search_cache VALUES (?, ?, ?, ?, ?)",
                (query_hash, query, results_json, datetime.now(), 24)
            )
    
    def get_cached_content(self, url: str) -> Optional[str]:
        """Retrieve cached content if available and not expired."""
        url_hash = self._get_hash(url)
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.execute(
                "SELECT content, timestamp FROM content_cache WHERE url_hash = ?",
                (url_hash,)
            )
            row = cursor.fetchone()
            if row:
                content, timestamp_str = row
                timestamp = datetime.fromisoformat(timestamp_str)
                if datetime.now() - timestamp < self.ttl:
                    return content
        return None
    
    def cache_content(self, url: str, content: str):
        """Cache crawled content with TTL."""
        url_hash = self._get_hash(url)
        with sqlite3.connect(self.db_path) as conn:
            conn.execute(
                "INSERT OR REPLACE INTO content_cache VALUES (?, ?, ?, ?, ?)",
                (url_hash, url, content, datetime.now(), 24)
            )

# ---------------------------------------------------------------------------
# Semantic Search Engine
# ---------------------------------------------------------------------------

# Only define SemanticSearcher if semantic features are available
if HAS_SEMANTIC:
    class SemanticSearcher:
        """AI-powered semantic search and relevance scoring."""
        
        def __init__(self):
            self.model = SentenceTransformer('all-MiniLM-L6-v2')
            self.domain_authority = {
                'wikipedia.org': 0.9,
                'github.com': 0.85,
                'stackoverflow.com': 0.85,
                'medium.com': 0.8,
                'dev.to': 0.75,
                'reddit.com': 0.7,
            }
        
        def get_embedding(self, text: str) -> np.ndarray:
            """Get text embedding with caching."""
            text_hash = hashlib.md5(text.encode()).hexdigest()
            # Note: In production, this would use the cache system
            return self.model.encode(text)
        
        def score_relevance(self, query: str, result: SearchResult) -> float:
            """Calculate relevance score using semantic similarity and domain authority."""
            try:
                # Semantic similarity
                query_embedding = self.get_embedding(query)
                content_text = f"{result.title} {result.snippet}"
                content_embedding = self.get_embedding(content_text)
                
                similarity = cosine_similarity(
                    query_embedding.reshape(1, -1),
                    content_embedding.reshape(1, -1)
                )[0][0]
                
                # Domain authority boost
                domain = urlparse(result.url).netloc.lower()
                authority_boost = self.domain_authority.get(domain, 0.5)
                
                # Combined score
                relevance_score = (similarity * 0.7) + (authority_boost * 0.3)
                return float(relevance_score)
                
            except Exception as e:
                logging.warning(f"Failed to calculate relevance score: {e}")
                return 0.5  # Default score
else:
    # Fallback class when semantic features are not available
    class SemanticSearcher:
        """Fallback semantic search when dependencies are not available."""
        
        def __init__(self):
            self.domain_authority = {
                'wikipedia.org': 0.9,
                'github.com': 0.85,
                'stackoverflow.com': 0.85,
                'medium.com': 0.8,
                'dev.to': 0.75,
                'reddit.com': 0.7,
            }
        
        def score_relevance(self, query: str, result: SearchResult) -> float:
            """Simple relevance scoring based on domain authority only."""
            try:
                # Domain authority boost only
                domain = urlparse(result.url).netloc.lower()
                authority_boost = self.domain_authority.get(domain, 0.5)
                return float(authority_boost)
            except Exception as e:
                logging.warning(f"Failed to calculate relevance score: {e}")
                return 0.5  # Default score

# ---------------------------------------------------------------------------
# AI Content Analyzer
# ---------------------------------------------------------------------------

class ContentAnalyzer:
    """AI-powered content analysis and summarization."""
    
    def __init__(self):
        self.summarizer = None
        self.sentiment_analyzer = None
        self.ner_model = None
        
        if HAS_TRANSFORMERS:
            try:
                self.summarizer = pipeline("summarization", model="facebook/bart-large-cnn")
                self.sentiment_analyzer = pipeline("sentiment-analysis")
                self.ner_model = pipeline("ner", aggregation_strategy="simple")
            except Exception as e:
                logging.warning(f"Failed to load AI models: {e}")
    
    def analyze_content(self, content: str, query: str) -> ContentAnalysis:
        """Perform comprehensive content analysis."""
        analysis = ContentAnalysis()
        
        if not content or not HAS_TRANSFORMERS:
            return analysis
        
        try:
            # Summarization (truncate if too long)
            text_to_summarize = content[:1024] if len(content) > 1024 else content
            if self.summarizer and len(text_to_summarize) > 50:
                summary_result = self.summarizer(text_to_summarize, max_length=150, min_length=30)
                analysis.summary = summary_result[0]['summary_text']
            
            # Sentiment analysis
            if self.sentiment_analyzer:
                sentiment_result = self.sentiment_analyzer(content[:512])
                analysis.sentiment = sentiment_result[0]['label'].lower()
            
            # Named entity recognition
            if self.ner_model:
                entities_result = self.ner_model(content[:512])
                analysis.entities = [
                    Entity(text=ent['word'], label=ent['entity_group'], confidence=ent['score'])
                    for ent in entities_result
                ]
            
            # Key points extraction (simple heuristic)
            analysis.key_points = self._extract_key_points(content)
            
            # Topic classification (simple keyword-based)
            analysis.topic = self._classify_topic(content, query)
            
        except Exception as e:
            logging.warning(f"Content analysis failed: {e}")
        
        return analysis
    
    def _extract_key_points(self, content: str) -> List[str]:
        """Extract key points using simple heuristics."""
        sentences = re.split(r'[.!?]+', content)
        # Filter for sentences with important keywords
        important_keywords = ['important', 'key', 'main', 'primary', 'essential', 'crucial']
        key_points = []
        
        for sentence in sentences[:10]:  # Limit to first 10 sentences
            sentence = sentence.strip()
            if len(sentence) > 20 and any(keyword in sentence.lower() for keyword in important_keywords):
                key_points.append(sentence)
        
        return key_points[:3]  # Return top 3 key points
    
    def _classify_topic(self, content: str, query: str) -> str:
        """Simple topic classification based on keywords."""
        topic_keywords = {
            'technology': ['software', 'programming', 'code', 'tech', 'computer', 'digital'],
            'business': ['business', 'company', 'market', 'finance', 'economy', 'investment'],
            'science': ['research', 'study', 'experiment', 'scientific', 'data', 'analysis'],
            'health': ['health', 'medical', 'medicine', 'treatment', 'disease', 'patient'],
            'education': ['education', 'learning', 'school', 'university', 'student', 'course'],
        }
        
        content_lower = content.lower() + " " + query.lower()
        topic_scores = {}
        
        for topic, keywords in topic_keywords.items():
            score = sum(1 for keyword in keywords if keyword in content_lower)
            topic_scores[topic] = score
        
        return max(topic_scores, key=topic_scores.get) if topic_scores else 'general'

# ---------------------------------------------------------------------------
# HTML text extractor (enhanced)
# ---------------------------------------------------------------------------

class ContentExtractor(HTMLParser):
    """Enhanced HTML parser to extract clean text content."""

    def __init__(self, max_length: int = 3000):
        super().__init__()
        self.max_length = max_length
        self.content: List[str] = []
        self.in_script = False
        self.in_style = False
        self.current_length = 0

    def handle_starttag(self, tag, attrs):
        if tag == "script":
            self.in_script = True
        elif tag == "style":
            self.in_style = True
        elif tag in ("p", "div", "h1", "h2", "h3", "h4", "h5", "h6", "li", "span"):
            if self.content and self.content[-1] not in (" ", "\n"):
                self.content.append(" ")

    def handle_endtag(self, tag):
        if tag == "script":
            self.in_script = False
        elif tag == "style":
            self.in_style = False
        elif tag in ("p", "div", "li"):
            if self.content and self.content[-1] != "\n":
                self.content.append("\n")

    def handle_data(self, data):
        if self.in_script or self.in_style:
            return
        if data.strip():
            words = data.split()
            for word in words:
                if self.current_length >= self.max_length:
                    return
                self.content.append(word)
                self.current_length += len(word) + 1

    def get_text(self) -> str:
        """Return cleaned text content."""
        text = " ".join(self.content)
        return " ".join(text.split())

