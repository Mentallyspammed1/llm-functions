    def get_orderbook(
        self,
        symbol:   str,
        limit:    int      = 25,
        category: Category = Category.LINEAR,
    ) -> dict:
        return self.api_request(
            "GET",
            "/v5/market/orderbook",
            params={"category": category, "symbol": symbol, "limit": limit},
            signed=False,
        )

    def get_klines(
        self,
        symbol:   str,
        interval: str      = "1",
        limit:    int      = 200,
        category: Category = Category.LINEAR,
    ) -> List[dict]:
        resp = self.api_request(
            "GET",
