#!/usr/bin/env python3
# ==============================================================================
# bybit_get_balance.py — Bybit Get Balance Tool (Tor-Ready)
#
# @describe Get wallet balance from Bybit exchange using V5 API
# @option --account-type <UNIFIED|CONTRACT|SPOT>  Account type (default: UNIFIED)
# @option --testnet <true|false>                 Use testnet (default: true)
# @option --api-key <KEY>                        API key (optional, can use env var)
# @option --api-secret <SECRET>                  API secret (optional, can use env var)
# @option --use-tor <true|false>                 Route through Tor (default: true)
# ==============================================================================

import os
import json
import hmac
import hashlib
import time
import requests
import socket
import re
from urllib.parse import urlencode
from typing import Optional, Tuple


# --------------------------------------------------------------------------
# Tor Configuration
# --------------------------------------------------------------------------
TOR_SOCKS_HOST: str = os.environ.get("TOR_SOCKS_HOST", "127.0.0.1")
TOR_SOCKS_PORT: int = int(os.environ.get("TOR_SOCKS_PORT", "9050"))

# socks5h:// — DNS resolved on Tor exit node
_SOCKS5H_PROXY: str = f"socks5h://{TOR_SOCKS_HOST}:{TOR_SOCKS_PORT}"
TOR_PROXIES: dict = {
    "http": _SOCKS5H_PROXY,
    "https": _SOCKS5H_PROXY,
}

# Timeouts
TOR_CONNECT_TIMEOUT: float = 15.0
TOR_READ_TIMEOUT: float = 30.0

# Symbol validation
SYMBOL_PATTERN = re.compile(r'^[A-Z]{2,10}USDT?$')


# --------------------------------------------------------------------------
# Tor Utilities
# --------------------------------------------------------------------------
def _socks_port_open() -> bool:
    """Check if Tor SOCKS port is accepting connections."""
    try:
        with socket.create_connection((TOR_SOCKS_HOST, TOR_SOCKS_PORT), timeout=5):
            return True
    except OSError:
        return False


def verify_tor_connection() -> str:
    """Verify traffic is routing through Tor."""
    if not _socks_port_open():
        raise RuntimeError(f"Tor SOCKS port {TOR_SOCKS_HOST}:{TOR_SOCKS_PORT} not reachable.")

    check_url = "https://check.torproject.org/api/ip"
    try:
        resp = requests.get(
            check_url,
            proxies=TOR_PROXIES,
            timeout=(TOR_CONNECT_TIMEOUT, TOR_READ_TIMEOUT),
            headers={"User-Agent": "Mozilla/5.0 (Windows NT 10.0; rv:109.0) Gecko/20100101 Firefox/115.0"},
        )
        resp.raise_for_status()
        data = resp.json()
    except Exception as exc:
        raise RuntimeError(f"Tor check request failed: {exc}") from exc

    if not data.get("IsTor", False):
        raise RuntimeError(f"Traffic NOT routing through Tor. IP: {data.get('IP', 'unknown')}")

    return data.get("IP", "hidden")


def run(
    account_type: str = "UNIFIED",
    testnet: bool = True,
    api_key: Optional[str] = None,
    api_secret: Optional[str] = None,
    use_tor: bool = True,
):
    """
    Get wallet balance from Bybit exchange using V5 API
    """

    # Get API credentials from parameters or environment
    api_key = api_key or os.environ.get("BYBIT_API_KEY")
    api_secret = api_secret or os.environ.get("BYBIT_API_SECRET")

    if not api_key or not api_secret:
        return "Error: API key and secret are required. Set BYBIT_API_KEY and BYBIT_API_SECRET environment variables or provide --api-key and --api-secret parameters."

    # Verify Tor connection if enabled
    if use_tor:
        try:
            exit_ip = verify_tor_connection()
        except RuntimeError as exc:
            return f"❌ Tor Error: {exc}"

    # Set base URL
    base_url = "https://api-testnet.bybit.com" if testnet else "https://api.bybit.com"

    # Prepare request parameters
    params = {
        "accountType": account_type,
    }

    # Generate timestamp and signature
    timestamp = str(int(time.time() * 1000))
    recv_window = "20000"  # Wider for Tor latency

    # Create signature for GET request
    query_string = urlencode(params)
    param_str = timestamp + api_key + recv_window + query_string
    signature = hmac.new(
        api_secret.encode("utf-8"), param_str.encode("utf-8"), hashlib.sha256
    ).hexdigest()

    # Prepare headers
    headers = {
        "X-BAPI-API-KEY": api_key,
        "X-BAPI-TIMESTAMP": timestamp,
        "X-BAPI-SIGN": signature,
        "X-BAPI-RECV-WINDOW": recv_window,
        "Content-Type": "application/json",
    }

    # Use Tor proxies if enabled
    proxies = TOR_PROXIES if use_tor else {}
    timeout = (TOR_CONNECT_TIMEOUT, TOR_READ_TIMEOUT) if use_tor else 30

    try:
        # Make the request
        response = requests.get(
            f"{base_url}/v5/account/wallet-balance",
            headers=headers,
            params=params,
            proxies=proxies if proxies else None,
            timeout=timeout,
        )

        try:
            response_data = response.json()
        except json.JSONDecodeError:
            return f"""❌ API Response Error!
Status Code: {response.status_code}
Response Text: {response.text}

This often happens if the API is blocked by CloudFront or a firewall.
"""

        if response.status_code == 200 and response_data.get("retCode") == 0:
            result = response_data.get("result", {})
            list_data = result.get("list", [])

            if list_data:
                account_info = list_data[0]
                total_equity = account_info.get("totalEquity", "0")
                total_wallet_balance = account_info.get("totalWalletBalance", "0")
                total_margin_balance = account_info.get("totalMarginBalance", "0")
                total_available_balance = account_info.get("totalAvailableBalance", "0")

                # Format coin balances
                coin_balances = []
                for coin in account_info.get("coin", []):
                    coin_balances.append(f"""
{coin.get("coin", "N/A")}: 
  Wallet: {coin.get("walletBalance", "0")}
  Available: {coin.get("availableToWithdraw", "0")}
  Locked: {coin.get("locked", "0")}
""")

                return f"""✅ Balance Retrieved Successfully!
Network: {'Tor' if use_tor else 'Direct'}
Exit IP: {exit_ip if use_tor else 'N/A'}

Account Type: {account_type}
Total Equity: {total_equity}
Total Wallet Balance: {total_wallet_balance}
Total Margin Balance: {total_margin_balance}
Total Available Balance: {total_available_balance}

Coin Balances:
{"".join(coin_balances)}

Full Response:
{json.dumps(response_data, indent=2)}"""
            else:
                return f"""✅ Balance Retrieved Successfully!
No account data found.

Full Response:
{json.dumps(response_data, indent=2)}"""
        else:
            return f"""❌ Balance Retrieval Failed!
Status Code: {response.status_code}
Error Code: {response_data.get("retCode", "N/A")}
Error Message: {response_data.get("retMsg", "Unknown error")}

Full Response:
{json.dumps(response_data, indent=2)}"""

    except requests.exceptions.RequestException as e:
        return f"❌ Network Error: {str(e)}"
    except Exception as e:
        return f"❌ Unexpected Error: {str(e)}"


if __name__ == "__main__":
    import argparse

    parser = argparse.ArgumentParser()
    parser.add_argument("--account-type", default="UNIFIED")
    parser.add_argument("--testnet", type=lambda x: str(x).lower() == "true", default=True)
    parser.add_argument("--api-key")
    parser.add_argument("--api-secret")
    parser.add_argument("--use-tor", type=lambda x: str(x).lower() == "true", default=True)
    args = parser.parse_args()
    kwargs = {k: v for k, v in vars(args).items() if v is not None}
    print(run(**kwargs))
