        )
        return resp.get("result", {}).get("list", [])

    def get_open_interest(
        self,
        symbol:        str,
        interval_time: str      = "5min",
        category:      Category = Category.LINEAR,
        limit:         int      = 50,
    ) -> List[dict]:
        resp = self.api_request(
            "GET",
