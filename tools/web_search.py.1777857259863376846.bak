_USER_AGENTS: List[str] = [
    "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36",
    "Mozilla/5.0 (Macintosh; Intel Mac OS X 14_4) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.4.1 Safari/605.1.15",
    "Mozilla/5.0 (X11; Linux x86_64; rv:125.0) Gecko/20100101 Firefox/125.0",
    "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36 Edg/123.0.0.0",
]

_USER_AGENT = random.choice(_USER_AGENTS)

def _random_user_agent() -> str:
    """Return a randomly selected User-Agent string."""
    return random.choice(_USER_AGENTS)

# ---------------------------------------------------------------------------
# Block / CAPTCHA detection (enhanced)
# ---------------------------------------------------------------------------

_BLOCK_SIGNALS: List[str] = [
    "unusual traffic", "captcha", "ip blocked", "access denied",
    "enable javascript", "please verify you are a human", "sorry, we can't",
    "automated queries", "to continue, please", "robot check", "bot detection"
]

def _is_blocked(html: str) -> bool:
    """Detect bot block pages with enhanced patterns."""
    sample = html[:4096].lower()
    return any(signal in sample for signal in _BLOCK_SIGNALS)

# ---------------------------------------------------------------------------
# Low-level HTTP fetch (enhanced)
# ---------------------------------------------------------------------------

def _build_cmd(fetcher: str, url: str, timeout: int, user_agent: str) -> List[str]:
    """Build HTTP command with enhanced headers."""
    common_headers = [
        "Accept: text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
        "Accept-Language: en-US,en;q=0.5",
        "Accept-Encoding: gzip, deflate, br",
        "DNT: 1",
        "Connection: keep-alive",
        "Upgrade-Insecure-Requests: 1",
    ]

    if fetcher in ("curlie", "curl"):
        binary = CURLIE_BIN if fetcher == "curlie" else CURL_BIN
        cmd = [
            binary, "-s", "-S", "-L", "--compressed",
            "--max-time", str(timeout),
            "-H", f"User-Agent: {user_agent}",
        ]
        for h in common_headers:
            cmd += ["-H", h]
        cmd.append(url)

    elif fetcher == "wget2":
        cmd = [
            WGET2_BIN, "-q", "-O", "-",
            f"--timeout={timeout}",
            f"--user-agent={user_agent}",
            "--max-redirect=5",
            "--compression=auto",
        ]
        for h in common_headers:
            cmd.append(f"--header={h}")
        cmd.append(url)

    else:  # legacy wget
        cmd = [
            WGET_BIN, "-q", "-O", "-",
            f"--timeout={timeout}",
            f"--user-agent={user_agent}",
        ]
        for h in common_headers:
            cmd.append(f"--header={h}")
        cmd.append(url)

    return cmd

def _fetch_url(
    url: str,
    timeout: int = 10,
    verbose: bool = False,
    user_agent: Optional[str] = None,
) -> str:
    """Fetch URL with enhanced error handling."""
    logger = logging.getLogger(__name__)
    fetcher = _preferred_fetcher()
    ua = user_agent or _USER_AGENT
    cmd = _build_cmd(fetcher, url, timeout, ua)

    if verbose:
        logger.debug("Fetch command: %s", " ".join(cmd))

    proc = subprocess.run(
        cmd,
        capture_output=True,
        text=True,
        timeout=timeout + 5,
    )

    if proc.returncode != 0:
        stderr = proc.stderr.strip()
        raise RuntimeError(f"{fetcher} failed (rc={proc.returncode}): {stderr}")

    return proc.stdout

# ---------------------------------------------------------------------------
# Content extraction helpers (enhanced)
# ---------------------------------------------------------------------------

def _extract_text(html: str, max_length: int = 3000) -> str:
    """Extract text with enhanced processing."""
    if HAS_BS4:
        soup = BeautifulSoup(html, "html.parser")
        for tag in soup(["script", "style", "noscript", "nav", "footer", "header"]):
            tag.decompose()
        text = soup.get_text(separator=" ", strip=True)
        return text[:max_length]

    extractor = ContentExtractor(max_length)
    extractor.feed(html)
    return extractor.get_text()

# ---------------------------------------------------------------------------
# Enhanced Search Engine Parsers
# ---------------------------------------------------------------------------

def _parse_duckduckgo(html: str, num_results: int) -> List[Dict[str, str]]:
    """Parse DuckDuckGo results with enhanced extraction."""
    results: List[Dict[str, str]] = []

    if HAS_BS4:
        soup = BeautifulSoup(html, "html.parser")
        for r in soup.select("div.result:not(.result--ad)"):
            a_tag = r.select_one("a.result__a")
            snippet_el = r.select_one("a.result__snippet")
            if not a_tag:
                continue

            href = a_tag.get("href", "")
            if "uddg=" in href:
                m = re.search(r"uddg=([^&]+)", href)
                if m:
                    href = urllib.parse.unquote(m.group(1))

            if not href.startswith("http"):
                continue

            results.append({
                "url": href,
                "title": a_tag.get_text(strip=True),
                "snippet": snippet_el.get_text(strip=True) if snippet_el else "",
            })
            if len(results) >= num_results:
                break

    else:
        for m in re.finditer(r"uddg=(https?[^&\"]+)", html):
            results.append({
                "url": urllib.parse.unquote(m.group(1)),
                "title": "",
                "snippet": "",
            })
            if len(results) >= num_results:
                break

    return results

def _parse_google(html: str, num_results: int) -> List[Dict[str, str]]:
    """Parse Google results with enhanced extraction."""
    results: List[Dict[str, str]] = []

    if HAS_BS4:
        soup = BeautifulSoup(html, "html.parser")
        for block in soup.select("div.g"):
            a_tag = block.select_one("a[href]")
            if not a_tag:
                continue

            href = a_tag.get("href", "")
            if "/url?q=" in href:
                m = re.search(r"/url\?q=([^&]+)", href)
                if m:
                    href = urllib.parse.unquote(m.group(1))

            if not href.startswith("http") or "google.com" in href:
                continue

            title = a_tag.get_text(strip=True)
            snippet = ""
            snippet_el = (
                block.select_one("div.VwiC3b")
                or block.select_one("span.st")
            )
            if snippet_el:
                snippet = snippet_el.get_text(strip=True)

            results.append({"url": href, "title": title, "snippet": snippet})
            if len(results) >= num_results:
                break

    else:
        for m in re.finditer(r"/url\?q=(https?://[^&\"]+)", html):
            url = urllib.parse.unquote(m.group(1))
            if "google.com" not in url:
                results.append({"url": url, "title": "", "snippet": ""})
                if len(results) >= num_results:
                    break

    return results

def _parse_bing(html: str, num_results: int) -> List[Dict[str, str]]:
    """Parse Bing search results."""
    results: List[Dict[str, str]] = []

    if HAS_BS4:
        soup = BeautifulSoup(html, "html.parser")
        for li in soup.select("li.b_algo"):
            a_tag = li.select_one("h2 a")
            if not a_tag:
                continue

            href = a_tag.get("href", "")
            if not href.startswith("http"):
                continue

            title = a_tag.get_text(strip=True)
            snippet_el = li.select_one("p")
            snippet = snippet_el.get_text(strip=True) if snippet_el else ""

            results.append({"url": href, "title": title, "snippet": snippet})
            if len(results) >= num_results:
                break

    return results

def _parse_brave(html: str, num_results: int) -> List[Dict[str, str]]:
    """Parse Brave search results."""
    results: List[Dict[str, str]] = []

    if HAS_BS4:
        soup = BeautifulSoup(html, "html.parser")
        for div in soup.select("div.web-result"):
            a_tag = div.select_one("a.result-header")
            if not a_tag:
                continue

            href = a_tag.get("href", "")
            if not href.startswith("http"):
                continue

            title = a_tag.get_text(strip=True)
            snippet_el = div.select_one(".snippet")
            snippet = snippet_el.get_text(strip=True) if snippet_el else ""

            results.append({"url": href, "title": title, "snippet": snippet})
            if len(results) >= num_results:
                break

    return results

# ---------------------------------------------------------------------------
# Retry helper (enhanced)
# ---------------------------------------------------------------------------

def _fetch_with_retry(
    url: str,
    timeout: int,
    verbose: bool,
    retries: int = 3,
    backoff: float = 1.5,
) -> str:
    """Enhanced retry with exponential backoff."""
    last_exc: Optional[Exception] = None
    for attempt in range(1, retries + 1):
        try:
            return _fetch_url(
                url,
                timeout=timeout,
                verbose=verbose,
                user_agent=_random_user_agent(),
            )
        except Exception as exc:
            last_exc = exc
            if attempt < retries:
                wait = backoff ** attempt + random.uniform(0, 0.5)
                logging.getLogger(__name__).warning(
                    "Fetch attempt %d/%d failed for %s: %s — retrying in %.1fs",
                    attempt, retries, url, exc, wait,
                )
                time.sleep(wait)
    raise RuntimeError(f"All {retries} fetch attempts failed: {last_exc}") from last_exc

# ---------------------------------------------------------------------------
# Multi-Source Search Engine (NEW)
# ---------------------------------------------------------------------------

def _multi_source_search(
    query: str,
    num_results: int = 10,
    lang: str = "en",
    region: str = "us",
    timeout: int = 10,
    verbose: bool = False,
) -> List[Dict[str, str]]:
    """Enhanced multi-source search with intelligent aggregation."""
    logger = logging.getLogger(__name__)
    encoded_query = urllib.parse.quote_plus(query)

    engines = [
        {
            "name": "DuckDuckGo",
            "url": f"https://html.duckduckgo.com/html/?q={encoded_query}&kl={region}-{lang}",
            "parser": _parse_duckduckgo,
            "weight": 1.0,
        },
        {
            "name": "Google",
            "url": f"https://www.google.com/search?q={encoded_query}&hl={lang}&gl={region}&num={num_results}",
            "parser": _parse_google,
            "weight": 1.2,
        },
        {
            "name": "Bing",
            "url": f"https://www.bing.com/search?q={encoded_query}&setlang={lang}",
            "parser": _parse_bing,
            "weight": 0.9,
        },
        {
            "name": "Brave",
            "url": f"https://search.brave.com/search?q={encoded_query}",
            "parser": _parse_brave,
            "weight": 0.8,
        },
    ]

    all_results = []
    engine_results = {}

    for engine in engines:
        try:
            logger.info("Trying %s search", engine["name"])
            html = _fetch_with_retry(engine["url"], timeout=timeout, verbose=verbose)

            if _is_blocked(html):
                logger.warning("%s returned a block/CAPTCHA page — skipping", engine["name"])
                continue

            parsed = engine["parser"](html, num_results)
            if parsed:
                # Add engine info and weight
                for result in parsed:
                    result["source_engine"] = engine["name"]
                    result["weight"] = engine["weight"]
                
                engine_results[engine["name"]] = parsed
                logger.info("Got %d results from %s", len(parsed), engine["name"])

        except Exception as exc:
            logger.warning("%s search failed: %s", engine["name"], exc)

    # Aggregate and deduplicate results
    all_results = _aggregate_and_deduplicate(engine_results, num_results)
    return all_results

def _aggregate_and_deduplicate(engine_results: Dict[str, List[Dict]], num_results: int) -> List[Dict[str, str]]:
    """Intelligent aggregation with deduplication."""
    logger = logging.getLogger(__name__)
    
    # Collect all results with their sources
    all_results = []
    seen_urls = set()
    seen_domains = set()
    
    for engine_name, results in engine_results.items():
        for result in results:
            url = result["url"]
            domain = urlparse(url).netloc.lower()
            
            # Skip exact URL duplicates
            if url in seen_urls:
                continue
            
            # Skip too many results from same domain (max 3)
            if domain in seen_domains and sum(1 for r in all_results if urlparse(r["url"]).netloc.lower() == domain) >= 3:
                continue
            
            result["sources"] = [engine_name]
            all_results.append(result)
            seen_urls.add(url)
            seen_domains.add(domain)
    
    # Sort by weight and relevance
    all_results.sort(key=lambda x: x.get("weight", 1.0), reverse=True)
    
    logger.info("Aggregated %d unique results from %d engines", len(all_results), len(engine_results))
    return all_results[:num_results]

# ---------------------------------------------------------------------------
# Advanced Filtering (NEW)
# ---------------------------------------------------------------------------

def _apply_filters(results: List[Dict[str, str]], filters: SearchFilters) -> List[Dict[str, str]]:
    """Apply advanced filtering to search results."""
    filtered_results = []
    
    for result in results:
        url = result["url"]
        domain = urlparse(url).netloc.lower()
        
        # Domain filtering
        if filters.include_domains and not any(d in domain for d in filters.include_domains):
            continue
        if filters.exclude_domains and any(d in domain for d in filters.exclude_domains):
            continue
        
        # Content type filtering (simple heuristic)
        if filters.content_types:
            content_type = _detect_content_type(result)
            if content_type not in filters.content_types:
                continue
        
        # File type filtering
        if filters.file_types:
            file_ext = os.path.splitext(urlparse(url).path)[1].lower().lstrip('.')
            if file_ext and file_ext not in filters.file_types:
                continue
        
        filtered_results.append(result)
    
    return filtered_results

def _detect_content_type(result: Dict[str, str]) -> str:
    """Detect content type from URL and snippet."""
    url = result["url"].lower()
    snippet = result.get("snippet", "").lower()
    
    if any(site in url for site in ['wikipedia', 'scholar', 'arxiv', 'pubmed']):
        return 'academic'
    elif any(site in url for site in ['news', 'cnn', 'bbc', 'reuters']):
        return 'news'
    elif any(ext in url for ext in ['.pdf', '.doc', '.ppt']):
        return 'document'
    elif any(term in snippet for term in ['video', 'youtube', 'watch']):
        return 'video'
    elif any(term in snippet for term in ['image', 'photo', 'picture']):
        return 'image'
    
    return 'web'

# ---------------------------------------------------------------------------
# Enhanced URL crawling
# ---------------------------------------------------------------------------

def crawl_url(
    url: str,
    timeout: int = 10,
    max_length: int = 3000,
    verbose: bool = False,
    cache: Optional[SearchCache] = None,
) -> str:
    """Enhanced URL crawling with caching."""
    logger = logging.getLogger(__name__)
    
    # Check cache first
    if cache:
        cached_content = cache.get_cached_content(url)
        if cached_content:
            if verbose:
                logger.debug("Using cached content for %s", url)
            return cached_content
    
    if verbose:
        logger.debug("Crawling URL: %s", url)

    html = _fetch_url(
        url,
        timeout=timeout,
        verbose=verbose,
        user_agent=_random_user_agent(),
    )
    text = _extract_text(html, max_length)
    
    # Cache the content
    if cache and text:
        cache.cache_content(url, text)

    if verbose:
        logger.debug("Extracted %d characters from %s", len(text), url)
    return text

# ---------------------------------------------------------------------------
# Simulated results fallback (enhanced)
# ---------------------------------------------------------------------------

def simulate_search_results(query: str, num_results: int = 10) -> List[Dict[str, str]]:
    """Enhanced simulated results with more variety."""
    slug = urllib.parse.quote_plus(query)
    q_title = query.title()

    base = [
        {
            "url": f"https://en.wikipedia.org/wiki/{slug}",
            "title": f"{q_title} — Wikipedia",
            "snippet": f"Comprehensive Wikipedia article about {query}.",
            "source_engine": "simulated",
            "weight": 1.0,
        },
        {
            "url": f"https://www.google.com/search?q={slug}",
            "title": f"{q_title} — Google Search",
            "snippet": f"Latest Google search results for {query}.",
            "source_engine": "simulated",
            "weight": 0.9,
        },
        {
            "url": f"https://github.com/search?q={slug}",
            "title": f"{q_title} — GitHub",
            "snippet": f"Open source projects related to {query}.",
            "source_engine": "simulated",
            "weight": 0.8,
        },
        {
            "url": f"https://stackoverflow.com/search?q={slug}",
            "title": f"{q_title} — Stack Overflow",
            "snippet": f"Programming questions and answers about {query}.",
            "source_engine": "simulated",
            "weight": 0.8,
        },
        {
            "url": "https://docs.python.org/3/tutorial/",
            "title": "Python Tutorial",
            "snippet": "Official Python documentation and tutorials.",
            "source_engine": "simulated",
            "weight": 0.7,
        },
        {
            "url": "https://realpython.com/",
            "title": "Real Python",
            "snippet": "Python tutorials and guides for developers.",
            "source_engine": "simulated",
            "weight": 0.7,
        },
        {
            "url": "https://www.w3schools.com/python/",
            "title": "W3Schools Python",
            "snippet": "Interactive Python tutorials and examples.",
            "source_engine": "simulated",
            "weight": 0.6,
        },
        {
            "url": "https://pypi.org/",
            "title": "PyPI",
            "snippet": "Python Package Index - find and install packages.",
            "source_engine": "simulated",
            "weight": 0.6,
        },
        {
            "url": "https://github.com/python/cpython",
            "title": "CPython",
            "snippet": "The Python programming language source code.",
            "source_engine": "simulated",
            "weight": 0.6,
        },
        {
            "url": "https://stackoverflow.com/questions/tagged/python",
            "title": "SO Python",
            "snippet": "Python questions on Stack Overflow.",
            "source_engine": "simulated",
            "weight": 0.6,
        },
    ]
    return base[:num_results]

# ---------------------------------------------------------------------------
# Logging configuration (enhanced)
# ---------------------------------------------------------------------------

_logging_configured = False

def setup_logging(verbose: bool = False) -> None:
    """Enhanced logging configuration."""
    global _logging_configured
    if _logging_configured:
        return
    
    level = logging.DEBUG if verbose else logging.WARNING
    logging.basicConfig(
        level=level,
        format="%(asctime)s - %(name)s - %(levelname)s - %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S",
    )
    _logging_configured = True

# ---------------------------------------------------------------------------
# Query validation (enhanced)
# ---------------------------------------------------------------------------

def validate_query(query: str) -> None:
    """Enhanced query validation."""
    if not query or not query.strip():
        raise ValueError("Search query cannot be empty")
    
    if len(query.strip()) < 2:
        raise ValueError("Search query too short (minimum 2 characters)")
    
    if len(query) > 1000:
        raise ValueError("Search query too long (maximum 1000 characters)")

# ---------------------------------------------------------------------------
# Main Enhanced Search Orchestrator
# ---------------------------------------------------------------------------

def enhanced_search(
    query: str,
    num_results: int = 10,
    lang: str = "en",
    region: str = "us",
    safe_search: str = "moderate",
    pause: float = 2.0,
    crawl: bool = False,
    content_length: int = 3000,
    timeout: int = 10,
    verbose: bool = False,
    filters: Optional[SearchFilters] = None,
    use_semantic: bool = True,
    use_ai_analysis: bool = True,
) -> List[Dict[str, Any]]:
    """
    Enhanced web search with all advanced features.
    
    Args:
        query: Search query string.
        num_results: Number of results to return.
        lang: Language code.
        region: Region code.
        safe_search: Safe search level.
        pause: Seconds between crawl requests.
        crawl: Whether to crawl content.
        content_length: Maximum content length.
        timeout: Request timeout.
        verbose: Enable verbose logging.
        filters: Advanced filtering options.
        use_semantic: Enable semantic search scoring.
        use_ai_analysis: Enable AI content analysis.
    
    Returns:
        List of enhanced search results with AI analysis.
    """
    setup_logging(verbose)
    logger = logging.getLogger(__name__)
    
    validate_query(query)
    
    # Initialize components
    cache = SearchCache()
    semantic_searcher = SemanticSearcher() if use_semantic and HAS_SEMANTIC else None
    content_analyzer = ContentAnalyzer() if use_ai_analysis and HAS_TRANSFORMERS else None
    
    # Check cache first
    cached_results = cache.get_cached_results(query)
    if cached_results:
        logger.info("Using cached results for query: %s", query)
        return cached_results
    
    # Apply filters if provided
    if filters:
        logger.info("Applying advanced filters")
    
    # Multi-source search phase
    raw_results = _multi_source_search(
        query,
        num_results=num_results,
        lang=lang,
        region=region,
        timeout=timeout,
        verbose=verbose,
    )
    
    # Apply filters
    if filters:
        raw_results = _apply_filters(raw_results, filters)
    
    if not raw_results:
        logger.warning("All search engines failed — using simulated results")
        raw_results = simulate_search_results(query, num_results)
    
    logger.info("Found %d results", len(raw_results))
    
    # Build enhanced SearchResult objects
    results: List[Dict[str, Any]] = []
    
    for i, item in enumerate(raw_results[:num_results], 1):
        result = SearchResult(
            position=i,
            url=item["url"],
            title=item.get("title", ""),
            snippet=item.get("snippet", ""),
            content="",
            error="",
            source_engine=item.get("source_engine", "unknown"),
            relevance_score=0.0,
            content_analysis=None,
            crawl_timestamp=None,
        )
        
        # Semantic relevance scoring
        if semantic_searcher:
            result.relevance_score = semantic_searcher.score_relevance(query, result)
        
        # Content crawling and AI analysis
        if crawl:
            if verbose:
                logger.info("Crawling result %d: %s", i, item["url"])
            
            try:
                result.content = crawl_url(
                    item["url"],
                    timeout=timeout,
                    max_length=content_length,
                    verbose=verbose,
                    cache=cache,
                )
                result.crawl_timestamp = datetime.now()
                
                # AI content analysis
                if content_analyzer and result.content:
                    result.content_analysis = content_analyzer.analyze_content(result.content, query)
                
            except Exception as exc:
                result.error = str(exc)
                logger.warning("Failed to crawl %s: %s", item["url"], exc)
            
            # Pause between requests
            if i < len(raw_results):
                time.sleep(pause + random.uniform(0, 0.5))
        
        results.append(asdict(result))
        logger.debug("Result %d: %s (score: %.2f)", i, item["url"], result.relevance_score)
    
    # Sort by relevance score if semantic search is enabled
    if semantic_searcher:
        results.sort(key=lambda x: x["relevance_score"], reverse=True)
        # Reassign positions after sorting
        for i, result in enumerate(results, 1):
            result["position"] = i
    
    # Cache results
    cache.cache_results(query, [SearchResult(**r) for r in results])
    
    return results

# ---------------------------------------------------------------------------
# Public API - Backward Compatible
# ---------------------------------------------------------------------------

def run(
    query: str,
    limit: int = 10,
    lang: str = "en",
    region: str = "us",
    safe_search: Literal["off", "moderate", "strict"] = "moderate",
    pause: float = 2.0,
    crawl: bool = False,
    content_length: int = 3000,
    timeout: int = 10,
    verbose: bool = False,
):
    """Backward compatible entry point with enhanced features."""
    try:
        return enhanced_search(
            query=query,
            num_results=limit,
            lang=lang,
            region=region,
            safe_search=safe_search,
            pause=pause,
            crawl=crawl,
            content_length=content_length,
            timeout=timeout,
            verbose=verbose,
            filters=None,
            use_semantic=HAS_SEMANTIC,
            use_ai_analysis=HAS_TRANSFORMERS,
        )
    except (ValueError, RuntimeError):
        raise
    except Exception as exc:
        raise RuntimeError(f"An unexpected error occurred: {exc}") from exc

# ---------------------------------------------------------------------------
# Enhanced CLI Interface
# ---------------------------------------------------------------------------

def main() -> None:
    """Enhanced CLI interface with all new features."""
    parser = argparse.ArgumentParser(
        description="AI-Powered Enhanced Web Search Tool",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    
    # Basic arguments
    parser.add_argument("query", help="Search query")
    parser.add_argument("-n", "--num-results", type=int, default=10, help="Number of results")
    parser.add_argument("-l", "--lang", default="en", help="Language code")
    parser.add_argument("-r", "--region", default="us", help="Region code")
    parser.add_argument("-s", "--safe-search", choices=["off", "moderate", "strict"], default="moderate", help="Safe-search level")
    parser.add_argument("-p", "--pause", type=float, default=2.0, help="Pause between crawl requests")
    parser.add_argument("-c", "--crawl", action="store_true", help="Crawl content from result URLs")
    parser.add_argument("--content-length", type=int, default=3000, help="Max content length per page")
    parser.add_argument("-t", "--timeout", type=int, default=10, help="Request timeout")
    parser.add_argument("-v", "--verbose", action="store_true", help="Enable verbose output")
    
    # Enhanced features
    parser.add_argument("--no-semantic", action="store_true", help="Disable semantic search")
    parser.add_argument("--no-ai-analysis", action="store_true", help="Disable AI content analysis")
    parser.add_argument("--include-domains", nargs="+", help="Include only these domains")
    parser.add_argument("--exclude-domains", nargs="+", help="Exclude these domains")
    parser.add_argument("--content-types", nargs="+", choices=["web", "news", "academic", "video", "image"], help="Filter by content type")
    parser.add_argument("--file-types", nargs="+", help="Filter by file extension")
    parser.add_argument("--min-relevance", type=float, default=0.0, help="Minimum relevance score")
    
    args = parser.parse_args()
    
    # Build filters
    filters = None
    if any([args.include_domains, args.exclude_domains, args.content_types, args.file_types]):
        filters = SearchFilters(
            include_domains=args.include_domains or [],
            exclude_domains=args.exclude_domains or [],
            content_types=args.content_types or [],
            file_types=args.file_types or [],
            min_relevance_score=args.min_relevance,
        )
    
    try:
        results = enhanced_search(
            query=args.query,
            num_results=args.num_results,
            lang=args.lang,
            region=args.region,
            safe_search=args.safe_search,
            pause=args.pause,
            crawl=args.crawl,
            content_length=args.content_length,
            timeout=args.timeout,
            verbose=args.verbose,
            filters=filters,
            use_semantic=not args.no_semantic and HAS_SEMANTIC,
            use_ai_analysis=not args.no_ai_analysis and HAS_TRANSFORMERS,
        )
        
        # Enhanced output formatting
        output = {
            "query": args.query,
            "total_results": len(results),
            "features": {
                "semantic_search": not args.no_semantic and HAS_SEMANTIC,
                "ai_analysis": not args.no_ai_analysis and HAS_TRANSFORMERS,
                "caching": True,
                "multi_source": True,
            },
            "results": results
        }
        
        print(json.dumps(output, indent=2, default=str))
        
    except Exception as exc:
        print(f"Error: {exc}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
