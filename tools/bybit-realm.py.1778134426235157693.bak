if not NUMPY_AVAILABLE:
    _MISSING_DEPS.append("numpy")
if not REQUESTS_AVAILABLE:
    _MISSING_DEPS.append("requests")
if _MISSING_DEPS:
    logger.error(
        "Required packages missing: %s  "
        "Install with: pip install %s",
        ", ".join(_MISSING_DEPS),
        " ".join(_MISSING_DEPS),
    )
    sys.exit(1)


# ═══════════════════════════════════════════════════════════════
# DATACLASSES
# ═══════════════════════════════════════════════════════════════

@dataclass
class Position:
    """Represents a single open trading position."""
    position_idx:    int   = 0       # 0=one-way, 1=buy-side hedge, 2=sell-side hedge
    side:            str   = ""      # "Buy" | "Sell"
    size:            float = 0.0
    avg_price:       float = 0.0
    leverage:        float = 1.0
    unrealised_pnl:  float = 0.0
    liq_price:       float = 0.0
    take_profit:     str   = ""
    stop_loss:       str   = ""
    trailing_stop:   str   = ""
    position_status: str   = "Normal"
    created_time:    int   = 0
    updated_time:    int   = 0


@dataclass
class OpenOrder:
    """Represents a single open order."""
    order_id:      str            = ""
    symbol:        str            = ""
    side:          str            = ""
    order_type:    str            = ""
    qty:           float          = 0.0
    price:         float          = 0.0
    order_status:  str            = ""
    created_time:  int            = 0
    order_link_id: Optional[str]  = None


@dataclass
class OrderBookMetrics:
    """All computed metrics from an orderbook snapshot."""
    bid_volume_profile:   List[Tuple[float, float]] = field(default_factory=list)
    ask_volume_profile:   List[Tuple[float, float]] = field(default_factory=list)
    bid_depth_10:         float = 0.0
    ask_depth_10:         float = 0.0
    bid_depth_50:         float = 0.0
    ask_depth_50:         float = 0.0
    bid_depth_total:      float = 0.0
    ask_depth_total:      float = 0.0
    volume_imbalance:     float = 0.0
    order_flow_imbalance: float = 0.0
    bid_ask_spread:       float = 0.0
    spread_percentage:    float = 0.0
    buying_pressure:      float = 0.0
    selling_pressure:     float = 0.0
    market_pressure:      float = 0.0
    support_levels:       List[float] = field(default_factory=list)
    resistance_levels:    List[float] = field(default_factory=list)
    order_book_skew:      float = 0.0
    liquidity_ratio:      float = 0.0
    market_depth_ratio:   float = 0.0


@dataclass
class TradingSignal:
    """Encapsulates a single generated trading signal."""
    signal_type:   str   = ""   # LONG_ENTRY | SHORT_ENTRY | EXIT_LONG | EXIT_SHORT
    strength:      float = 0.0  # 0.0 – 1.0
    reason:        str   = ""
    trigger_price: float = 0.0
    stop_loss:     float = 0.0
    take_profit:   float = 0.0


@dataclass
class SymbolConfig:
    """Configuration specific to a single trading symbol."""
    symbol:           str   = ""
    leverage:         float = 5.0
    hedge_mode:       bool  = False
    orderbook_depth:  int   = 200
    max_daily_loss:   float = 50.0
    max_position_pct: float = 10.0
    profit_close_pct: float = 1.5
    use_conditional:  bool  = True
    # Instrument details — populated dynamically
    tick_size:        float = 0.01
    min_order_qty:    float = 0.001
    qty_step:         float = 0.001
    min_notional:     float = 5.0
    # Per-symbol fee overrides (populated from API)
    maker_fee:        float = 0.0001
    taker_fee:        float = 0.0006


@dataclass
class TradingConfig:
    """Overall bot configuration."""
    symbols:          List[SymbolConfig] = field(default_factory=list)
    interval:         int            = 5
    auto_trade:       bool           = False
    base_qty:         float          = 0.2
    min_profit:       float          = 2.0
    category:         str            = "linear"
    maker_fee:        float          = 0.0001
    taker_fee:        float          = 0.0006
    use_tor:          bool           = False
    tor_socks_port:   int            = 9050
    api_key:          Optional[str]  = None
    api_secret:       Optional[str]  = None
    max_daily_loss:   float          = 50.0
    max_position_pct: float          = 10.0


@dataclass
class AccountInfo:
    """Aggregated account balance and risk state."""
    total_equity:         float = 0.0
    available_balance:    float = 0.0
    total_wallet_balance: float = 0.0
    total_unrealized_pnl: float = 0.0
    daily_pnl:            float = 0.0
    margin_ratio:         float = 0.0
    risk_level:           str   = "LOW"
    total_position_value: float = 0.0


# ═══════════════════════════════════════════════════════════════
# GLOBAL STATE
# ═══════════════════════════════════════════════════════════════
config:       TradingConfig = TradingConfig()
account_info: AccountInfo   = AccountInfo()

current_positions:                    Dict[str, Optional[Position]]    = {}
open_orders_by_symbol:                Dict[str, Dict[str, OpenOrder]]  = {}
active_conditional_orders_by_symbol:  Dict[str, Dict[str, dict]]       = {}
orderbook_history_by_symbol:          Dict[str, deque]                 = {}
current_prices:                       Dict[str, float]                 = {}

emergency_stop: bool              = False
tor_manager:    Optional['TorManager']  = None
bybit_core:     Optional['BybitCore']   = None

# Thread-safety lock for emergency_stop writes
_emergency_lock = threading.Lock()


def initialize_all_symbol_states() -> None:
    """
    Initialise per-symbol dictionaries so every symbol has an entry
    before any strategy loop accesses them.
    """
    for sym_cfg in config.symbols:
        sym = sym_cfg.symbol
        current_positions.setdefault(sym, None)
        open_orders_by_symbol.setdefault(sym, {})
        active_conditional_orders_by_symbol.setdefault(sym, {})
        orderbook_history_by_symbol.setdefault(sym, deque(maxlen=100))
        current_prices.setdefault(sym, 0.0)
    logger.info(
        "Initialised state for symbols: %s",
        ", ".join(s.symbol for s in config.symbols),
    )


# ═══════════════════════════════════════════════════════════════
# NETWORKING LAYER
# ═══════════════════════════════════════════════════════════════

class TorManager:
    """Manages Tor connectivity and proxied HTTP requests."""

    def __init__(self, enabled: bool = False, socks_port: int = 9050):
        self.enabled:       bool                      = enabled
        self.socks_port:    int                       = socks_port
        self.session:       Optional[requests.Session] = None
        self.tor_available: bool                      = False
        self.proxy_url:     Optional[str]             = None

        if self.enabled:
            self._check_tor_availability()
            if self.tor_available:
                self._setup_session()

    # ── private helpers ───────────────────────────────────────
    def _check_tor_availability(self) -> bool:
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(3)
            result = sock.connect_ex(('127.0.0.1', self.socks_port))
            sock.close()
            if result == 0:
                logger.info("Tor available on port %d", self.socks_port)
                self.tor_available = True
                self.proxy_url = f'socks5://127.0.0.1:{self.socks_port}'
                return True
            logger.error(
                "Tor not available on port %d — using direct connection.",
                self.socks_port,
            )
            return False
        except Exception as exc:
            logger.error("Tor availability check failed: %s", exc)
            return False

    def _setup_session(self) -> None:
        try:
            self.session = requests.Session()
            self.session.proxies = {
                'http':  self.proxy_url,
                'https': self.proxy_url,
            }
            resp = self.session.get(
                'https://check.torproject.org/api/ip', timeout=10
            )
            if resp.status_code == 200:
                ip_info = resp.json()
                logger.info(
                    "Tor connected — IP: %s", ip_info.get('IP', 'Unknown')
                )
            else:
                logger.warning(
                    "Tor test returned status %d", resp.status_code
                )
        except Exception as exc:
            logger.error("Tor session setup failed: %s", exc)
            self.tor_available = False
            self.proxy_url     = None
            self.session       = None

    def renew_tor_identity(self) -> bool:
        """
        Request a new Tor circuit (identity) via the control port.
        Requires Tor control port (default 9051) to be accessible.
        """
        try:
            ctrl_port = self.socks_port + 1   # 9050 → 9051 by convention
            ctrl = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            ctrl.settimeout(5)
            ctrl.connect(('127.0.0.1', ctrl_port))
            ctrl.send(b'AUTHENTICATE ""\r\nSIGNAL NEWNYM\r\nQUIT\r\n')
            response = ctrl.recv(256).decode('utf-8', errors='replace')
            ctrl.close()
            if '250' in response:
                logger.info("Tor identity renewed successfully.")
                return True
            logger.warning("Tor identity renewal response: %s", response.strip())
            return False
        except Exception as exc:
            logger.warning("Tor identity renewal failed: %s", exc)
            return False

    # ── public interface ──────────────────────────────────────
    def make_request(
        self,
        method:    str,
        url:       str,
        headers:   Optional[dict] = None,
        params:    Optional[dict] = None,
        json_data: Optional[dict] = None,
        timeout:   int            = 30,
    ) -> dict:
        """Execute an HTTP request, using Tor proxy when available."""
        use_session = (
            self.enabled and self.tor_available and self.session is not None
        )
        requester = self.session if use_session else requests

        try:
            if method.upper() == 'GET':
                response = requester.get(
                    url, headers=headers, params=params, timeout=timeout
                )
            elif method.upper() == 'POST':
                response = requester.post(
                    url, headers=headers, json=json_data, timeout=timeout
                )
            else:
                raise ValueError(f"Unsupported HTTP method: {method}")

            response.raise_for_status()
            content_type = response.headers.get('content-type', '')
            parsed_json  = None
            if 'application/json' in content_type:
                parsed_json = response.json()
            return {
                'status_code': response.status_code,
                'text':        response.text,
                'json':        parsed_json,
            }

        except (
            requests.exceptions.ProxyError,
            requests.exceptions.ConnectionError,
        ) as exc:
            if use_session:
                logger.warning(
                    "Tor connection issue: %s — falling back to direct.", exc
                )
                self.tor_available = False
                self.session       = None
                # Single retry without Tor
                return self.make_request(
                    method, url, headers, params, json_data, timeout
                )
            logger.error("Network error (direct): %s", exc)
            raise

        except requests.exceptions.HTTPError as exc:
            logger.error("HTTP error: %s", exc)
            raise

        except requests.exceptions.Timeout as exc:
            logger.error("Request timed out: %s", exc)
            raise

        except requests.exceptions.RequestException as exc:
            logger.error("Request failed: %s", exc)
            raise

        except Exception as exc:
            logger.error("Unexpected request error: %s", exc)
            raise


class RateLimiter:
    """
    Token-bucket style rate limiter — enforces minimum inter-request gap.
    Thread-safe via lock.
    """

    def __init__(self, min_interval: float = 0.2):
        self.min_interval = min_interval
        self._last: float = 0.0
        self._lock = threading.Lock()

    def wait_if_needed(self) -> None:
        with self._lock:
            elapsed = time.time() - self._last
            if elapsed < self.min_interval:
                time.sleep(self.min_interval - elapsed)
            self._last = time.time()


class CircuitBreaker:
    """
    Prevents cascading failures by blocking calls after repeated errors.

    States: CLOSED → OPEN → HALF_OPEN → CLOSED
    """

    def __init__(self, failure_threshold: int = 5, timeout: int = 120):
        self.failure_threshold: int   = failure_threshold
        self.timeout:           int   = timeout
        self.failure_count:     int   = 0
        self.last_failure_time: float = 0.0
        self.state:             str   = "CLOSED"
        self._lock = threading.Lock()

    def call(self, func, *args, **kwargs):
        """Execute *func* with circuit-breaker protection."""
        with self._lock:
            if self.state == "OPEN":
                elapsed = time.time() - self.last_failure_time
                if elapsed > self.timeout:
                    self.state = "HALF_OPEN"
                    logger.warning("Circuit breaker → HALF_OPEN")
                else:
                    remaining = self.timeout - elapsed
                    raise ConnectionError(
                        f"Circuit breaker OPEN — retry in {remaining:.0f}s"
                    )

        try:
            result = func(*args, **kwargs)
            with self._lock:
                if self.state in ("HALF_OPEN", "CLOSED"):
                    if self.state == "HALF_OPEN":
                        logger.info("Circuit breaker → CLOSED (test passed)")
                    self.state         = "CLOSED"
                    self.failure_count = 0
            return result

        except Exception as exc:
            with self._lock:
                self.failure_count    += 1
                self.last_failure_time = time.time()
                if (
                    self.state == "HALF_OPEN"
                    or self.failure_count >= self.failure_threshold
                ):
                    self.state = "OPEN"
                    logger.error(
                        "Circuit breaker → OPEN after %d failures. %s",
                        self.failure_count, exc,
                    )
                else:
                    logger.warning(
                        "Circuit breaker failure %d/%d: %s",
                        self.failure_count, self.failure_threshold, exc,
                    )
            raise


# ═══════════════════════════════════════════════════════════════
# WEBSOCKET MANAGER
# ═══════════════════════════════════════════════════════════════

class WebSocketManager:
    """
    Manages both public and private Bybit V5 WebSocket streams
    for multiple symbols.
    """

    PUBLIC_URL  = "wss://stream.bybit.com/v5/public/linear"
    PRIVATE_URL = "wss://stream.bybit.com/v5/private"

    def __init__(self, bybit_core_instance: 'BybitCore'):
        self.bybit_core:        'BybitCore'         = bybit_core_instance
        self.ws_public:         Optional[Any]       = None
        self.ws_private:        Optional[Any]       = None
        self.running_public:    bool                = False
        self.running_private:   bool                = False
        self.subscribed_public: set                 = set()
        self.subscribed_private: set                = set()
        self.message_handlers:  Dict[str, Any]      = {}
        self.reconnect_interval: int                = 10
        self._stop_event = threading.Event()

    # ── handler registration ──────────────────────────────────
    def register_handler(self, topic_prefix: str, handler) -> None:
        """
        Register a callback for a topic prefix.
        Handlers are called as handler(topic: str, data: Any).
        """
        self.message_handlers[topic_prefix] = handler

    # ── message dispatch ──────────────────────────────────────
    def _dispatch(self, raw_message: str) -> None:
        try:
            data = json.loads(raw_message)

            # Heartbeat / pong
            if data.get("op") == "pong":
                logger.debug("WS pong received.")
                return

            # Auth / subscription confirmation
            if data.get("op") in ("auth", "subscribe"):
                success = data.get("success", False)
                logger.info("WS op=%s success=%s", data.get("op"), success)
                if not success:
                    logger.error(
                        "WS op=%s failed: %s",
                        data.get("op"),
                        data.get("ret_msg", "unknown"),
                    )
                return

            topic:   str = data.get("topic", "")
            payload      = data.get("data")

            if not topic or payload is None:
                logger.debug("WS non-topic message: %s", data)
                return

            # Route to registered handler — try most-specific prefix first
            parts = topic.split('.')
            for length in range(len(parts), 0, -1):
                prefix = '.'.join(parts[:length])
                if prefix in self.message_handlers:
                    try:
                        self.message_handlers[prefix](topic, payload)
                    except Exception as exc:
                        logger.error(
                            "Handler error for topic '%s': %s", topic, exc
                        )
                    return

            logger.debug("No handler for topic: %s", topic)

        except json.JSONDecodeError:
            logger.error("WS JSON decode error: %s", raw_message[:200])
        except Exception as exc:
            logger.error("WS dispatch error: %s", exc)

    # ── private-stream authentication ─────────────────────────
    def _authenticate_private(self, ws) -> None:
        """Send HMAC auth frame for private stream."""
        api_key    = self.bybit_core.api_key
        api_secret = self.bybit_core.api_secret
        if not api_key or not api_secret:
            logger.error("Cannot authenticate WS — API credentials missing.")
            return
        expires      = str(int((time.time() + 10) * 1000))
        sign_payload = f"GET/realtime{expires}"
        signature    = hmac.new(
            api_secret.encode(), sign_payload.encode(), hashlib.sha256
        ).hexdigest()
        auth_msg = {"op": "auth", "args": [api_key, expires, signature]}
        ws.send(json.dumps(auth_msg))
        logger.info("WS private auth frame sent.")

    # ── WebSocketApp callbacks ────────────────────────────────
    def _make_callbacks(self, stream_type: str):
        """Return (on_open, on_message, on_error, on_close) closures."""

        def on_open(ws):
            logger.info("WS %s connected.", stream_type)
            if stream_type == "private":
                self.running_private = True
                self._authenticate_private(ws)
                if self.subscribed_private:
                    ws.send(json.dumps({
                        "op":   "subscribe",
                        "args": list(self.subscribed_private),
                    }))
            else:
                self.running_public = True
                if self.subscribed_public:
                    ws.send(json.dumps({
                        "op":   "subscribe",
                        "args": list(self.subscribed_public),
                    }))

        def on_message(ws, message):
            self._dispatch(message)

        def on_error(ws, error):
            logger.error("WS %s error: %s", stream_type, error)
            if stream_type == "private":
                self.running_private = False
            else:
                self.running_public = False

        def on_close(ws, code, msg):
            logger.warning("WS %s closed: %s %s", stream_type, code, msg)
            if stream_type == "private":
                self.running_private = False
            else:
                self.running_public = False

        return on_open, on_message, on_error, on_close

    # ── connection launchers ──────────────────────────────────
    def _run_stream(self, url: str, stream_type: str) -> None:
        if not WEBSOCKET_AVAILABLE:
            logger.error("websocket-client not installed — cannot start WS.")
            return
        while not self._stop_event.is_set():
            try:
                on_open, on_message, on_error, on_close = (
                    self._make_callbacks(stream_type)
                )
                ws_app = websocket.WebSocketApp(
                    url,
                    on_open=on_open,
                    on_message=on_message,
                    on_error=on_error,
                    on_close=on_close,
                )
                if stream_type == "private":
                    self.ws_private = ws_app
                else:
                    self.ws_public = ws_app
                ws_app.run_forever(ping_interval=20, ping_timeout=10)
            except Exception as exc:
                logger.error("WS %s run_forever error: %s", stream_type, exc)
            if not self._stop_event.is_set():
                logger.info(
                    "WS %s reconnecting in %ds…",
                    stream_type, self.reconnect_interval,
                )
                time.sleep(self.reconnect_interval)

    def connect_public(self, topics: List[str]) -> None:
        self.subscribed_public.update(topics)
        t = threading.Thread(
            target=self._run_stream,
            args=(self.PUBLIC_URL, "public"),
            daemon=True,
            name="WS-Public",
        )
        t.start()

    def connect_private(self, topics: List[str]) -> None:
        self.subscribed_private.update(topics)
        t = threading.Thread(
            target=self._run_stream,
            args=(self.PRIVATE_URL, "private"),
            daemon=True,
            name="WS-Private",
        )
        t.start()

    def disconnect(self) -> None:
        self._stop_event.set()
        for ws in (self.ws_public, self.ws_private):
            if ws:
                try:
                    ws.close()
                except Exception:
                    pass
        logger.info("WebSocket connections closed.")


# ═══════════════════════════════════════════════════════════════
# BYBIT CORE API CLIENT
# ═══════════════════════════════════════════════════════════════

class BybitCore:
    """Authenticated Bybit V5 REST client with all resilience layers."""

    BASE_URL = "https://api.bybit.com"

    def __init__(
        self,
        api_key:    Optional[str]          = None,
        api_secret: Optional[str]          = None,
        base_url:   str                    = "https://api.bybit.com",
        tor_manager: Optional[TorManager]  = None,
    ):
        self.api_key        = api_key
        self.api_secret     = api_secret
        self.base_url       = base_url
        self.tor_manager    = tor_manager or TorManager(enabled=False)
        self.rate_limiter   = RateLimiter(min_interval=0.2)
        self.circuit_breaker = CircuitBreaker(failure_threshold=5, timeout=120)
        self.websocket_manager = WebSocketManager(self)

    # ── signature ─────────────────────────────────────────────
    def _generate_signature(
        self,
        params:      dict,
        method:      str,
        timestamp:   str,
        recv_window: str = "5000",
    ) -> str:
        """
        Bybit V5 HMAC-SHA256 signature.
        Sign string: {timestamp}{api_key}{recv_window}{body}
        GET  body = URL-encoded sorted query-string
        POST body = compact JSON payload
        """
        if method.upper() == 'GET' and params:
            body = "&".join(
                f"{k}={params[k]}" for k in sorted(params.keys())
            )
        elif method.upper() == 'POST' and params:
            body = json.dumps(params, separators=(',', ':'))
        else:
            body = ""

        sign_str  = f"{timestamp}{self.api_key}{recv_window}{body}"
        return hmac.new(
            self.api_secret.encode(),
            sign_str.encode(),
            hashlib.sha256,
        ).hexdigest()

    # ── core request ──────────────────────────────────────────
    def api_request(
        self,
        method:   str,
        endpoint: str,
        params:   Optional[dict] = None,
        signed:   bool           = False,
        timeout:  int            = 30,
        retries:  int            = 3,
    ) -> dict:
        """
        Unified REST request with rate-limiting, circuit-breaking,
        Tor proxy, optional HMAC signing, and automatic retries.
        """
        url            = f"{self.base_url}{endpoint}"
        headers: dict  = {
            'Content-Type': 'application/json',
            'User-Agent':   'BybitScalperBot/2.1',
        }
        request_params = params.copy() if params else {}
        recv_window    = "5000"

        if signed:
            if not self.api_key or not self.api_secret:
                return {
                    'retCode': -1,
                    'retMsg':  'API credentials not configured',
                }
            timestamp  = str(int(time.time() * 1000))
            signature  = self._generate_signature(
                request_params, method, timestamp, recv_window
            )
            headers.update({
                'X-BAPI-API-KEY':     self.api_key,
                'X-BAPI-TIMESTAMP':   timestamp,
                'X-BAPI-RECV-WINDOW': recv_window,
                'X-BAPI-SIGN':        signature,
            })

        last_exc: Optional[Exception] = None
        for attempt in range(1, retries + 1):
            try:
                self.rate_limiter.wait_if_needed()

                req_kwargs: dict = {
                    "method":  method,
                    "url":     url,
                    "headers": headers,
                    "timeout": timeout,
                }
                if method.upper() == 'GET':
                    req_kwargs["params"]    = request_params
                else:
                    req_kwargs["json_data"] = request_params

                response_data = self.circuit_breaker.call(
                    self.tor_manager.make_request, **req_kwargs
                )

                if response_data.get('json') is not None:
                    result = response_data['json']
                    # Surface Bybit API-level errors clearly
                    if result.get('retCode', 0) != 0:
                        logger.warning(
                            "Bybit API error on %s %s: [%d] %s",
                            method, endpoint,
                            result.get('retCode'), result.get('retMsg'),
                        )
                    return result

                return {
                    'retCode': -1,
                    'retMsg':  (
                        f"HTTP {response_data['status_code']}: "
                        f"{response_data['text'][:200]}"
                    ),
                }

            except ConnectionError as exc:
                # Circuit breaker is open — no point retrying immediately
                return {'retCode': -1, 'retMsg': f'Circuit breaker: {exc}'}

            except requests.exceptions.RequestException as exc:
                last_exc = exc
                if attempt < retries:
                    wait = 2 ** attempt          # exponential back-off
                    logger.warning(
                        "Request failed (attempt %d/%d), retrying in %ds: %s",
                        attempt, retries, wait, exc,
                    )
                    time.sleep(wait)
                else:
                    logger.error("Request failed after %d attempts: %s",
                                 retries, exc)

            except Exception as exc:
                logger.error(
                    "Unexpected API error on %s %s: %s",
                    method, endpoint, exc, exc_info=True,
                )
                return {'retCode': -1, 'retMsg': f'Unexpected error: {exc}'}

        return {
            'retCode': -1,
            'retMsg':  f'Network error after {retries} attempts: {last_exc}',
        }


# ═══════════════════════════════════════════════════════════════
# CONFIGURATION  (load / save)
# ═══════════════════════════════════════════════════════════════

CONFIG_FILE = "trading_config.json"


def load_config(filepath: str = CONFIG_FILE) -> bool:
    global config
    if not os.path.exists(filepath):
        logger.info("No config file found at %s — using defaults.", filepath)
        return False
    try:
        with open(filepath, 'r') as fh:
            data = json.load(fh)

        config.interval         = data.get("interval",         config.interval)
        config.auto_trade       = data.get("auto_trade",       config.auto_trade)
        config.base_qty         = data.get("base_qty",         config.base_qty)
        config.min_profit       = data.get("min_profit",       config.min_profit)
        config.category         = data.get("category",         config.category)
        config.maker_fee        = data.get("maker_fee",        config.maker_fee)
        config.taker_fee        = data.get("taker_fee",        config.taker_fee)
        config.use_tor          = data.get("use_tor",          config.use_tor)
        config.tor_socks_port   = data.get("tor_socks_port",   config.tor_socks_port)
        config.max_daily_loss   = data.get("max_daily_loss",   config.max_daily_loss)
        config.max_position_pct = data.get("max_position_pct", config.max_position_pct)

        # Credentials: file → env → None
        config.api_key    = (
            data.get("api_key")
            or os.environ.get("BYBIT_API_KEY")
        )
        config.api_secret = (
            data.get("api_secret")
            or os.environ.get("BYBIT_API_SECRET")
        )

        symbols_raw = data.get("symbols", [])
        if symbols_raw:
            config.symbols = []
            for s in symbols_raw:
                sym = s.get("symbol", "").strip().upper()
                if not sym:
                    continue
                sc = SymbolConfig(
                    symbol           = sym,
                    leverage         = s.get("leverage",         5.0),
                    hedge_mode       = s.get("hedge_mode",       False),
                    orderbook_depth  = s.get("orderbook_depth",  200),
                    max_daily_loss   = s.get("max_daily_loss",   50.0),
                    max_position_pct = s.get("max_position_pct", 10.0),
                    profit_close_pct = s.get("profit_close_pct", 1.5),
                    use_conditional  = s.get("use_conditional",  True),
                    maker_fee        = s.get("maker_fee",        config.maker_fee),
                    taker_fee        = s.get("taker_fee",        config.taker_fee),
                )
                config.symbols.append(sc)

        logger.info(
            "Config loaded from %s (%d symbols).",
            filepath, len(config.symbols),
        )
        return True

    except json.JSONDecodeError as exc:
        logger.error("Config file is not valid JSON: %s", exc)
        return False
    except Exception as exc:
        logger.error("Failed to load config from %s: %s", filepath, exc)
        return False


def save_config(filepath: str = CONFIG_FILE) -> None:
    data: dict = {
        "interval":         config.interval,
        "auto_trade":       config.auto_trade,
        "base_qty":         config.base_qty,
        "min_profit":       config.min_profit,
        "category":         config.category,
        "maker_fee":        config.maker_fee,
        "taker_fee":        config.taker_fee,
        "use_tor":          config.use_tor,
        "tor_socks_port":   config.tor_socks_port,
        "max_daily_loss":   config.max_daily_loss,
        "max_position_pct": config.max_position_pct,
        # Never persist credentials to disk in plain text
        "api_key":          None,
        "api_secret":       None,
        "symbols": [
            {
                "symbol":           s.symbol,
                "leverage":         s.leverage,
                "hedge_mode":       s.hedge_mode,
                "orderbook_depth":  s.orderbook_depth,
                "max_daily_loss":   s.max_daily_loss,
                "max_position_pct": s.max_position_pct,
                "profit_close_pct": s.profit_close_pct,
                "use_conditional":  s.use_conditional,
                "maker_fee":        s.maker_fee,
                "taker_fee":        s.taker_fee,
            }
            for s in config.symbols
        ],
    }
    try:
        # Write to a temp file then rename — atomic on POSIX
        tmp_path = filepath + ".tmp"
        with open(tmp_path, 'w') as fh:
            json.dump(data, fh, indent=2)
        os.replace(tmp_path, filepath)
        logger.info("Config saved to %s", filepath)
    except Exception as exc:
        logger.error("Failed to save config: %s", exc)


# ═══════════════════════════════════════════════════════════════
# NETWORKING / ENVIRONMENT INITIALISATION
# ═══════════════════════════════════════════════════════════════

def initialize_networking(
    use_tor:    bool,
    tor_port:   int,
    api_key:    Optional[str],
    api_secret: Optional[str],
) -> None:
    global tor_manager, bybit_core
    tor_manager = TorManager(enabled=use_tor, socks_port=tor_port)
    bybit_core  = BybitCore(
        api_key=api_key,
        api_secret=api_secret,
        tor_manager=tor_manager,
    )
    logger.info(
        "Network initialised — Tor: %s (port %d)",
        "Enabled" if use_tor else "Disabled", tor_port,
    )
    if use_tor and not tor_manager.tor_available:
        logger.warning("Tor requested but unavailable — direct connection used.")


def initialize_trading_environment_for_symbol(
    symbol_config: SymbolConfig,
) -> bool:
    """
    Fetch instrument specs and fee rates, set leverage and position mode
    for a single symbol.
    """
    symbol = symbol_config.symbol

    if not config.api_key or not config.api_secret:
        logger.error("[%s] API credentials missing.", symbol)
        return False
    if bybit_core is None:
        logger.error("BybitCore not initialised.")
        return False

    # ── Instrument info ───────────────────────────────────────
    resp = bybit_core.api_request(
        "GET", "/v5/market/instruments-info",
        params={"category": config.category, "symbol": symbol},
    )
    if resp.get("retCode") != 0:
        logger.error(
            "[%s] Instrument info error: %s", symbol, resp.get("retMsg")
        )
        return False

    instruments = resp.get("result", {}).get("list", [])
    if not instruments:
        logger.error("[%s] No instrument data returned.", symbol)
        return False

    inst = instruments[0]
    try:
        symbol_config.tick_size     = float(inst["priceFilter"]["tickSize"])
        symbol_config.min_order_qty = float(inst["lotSizeFilter"]["minOrderQty"])
        symbol_config.qty_step      = float(inst["lotSizeFilter"]["qtyStep"])
        symbol_config.min_notional  = float(
            inst["lotSizeFilter"].get("minNotionalValue", 5.0)
        )
    except (KeyError, ValueError) as exc:
        logger.error(
            "[%s] Failed to parse instrument filters: %s", symbol, exc
        )
        return False

    # ── Fee rates ─────────────────────────────────────────────
    fee_resp = bybit_core.api_request(
        "GET", "/v5/account/fee-rate",
        params={"category": config.category, "symbol": symbol},
        signed=True,
    )
    if fee_resp.get("retCode") == 0:
        fee_list = fee_resp.get("result", {}).get("list", [])
        if fee_list:
            # Store on the symbol config (not global) for per-symbol accuracy
            symbol_config.maker_fee = float(fee_list[0]["makerFeeRate"])
            symbol_config.taker_fee = float(fee_list[0]["takerFeeRate"])
    else:
        logger.warning(
            "[%s] Fee rate fetch failed: %s", symbol, fee_resp.get("retMsg")
        )

    # ── Leverage ──────────────────────────────────────────────
    if not validate_and_set_leverage_for_symbol(symbol_config):
        return False

    # ── Position mode ─────────────────────────────────────────
    mode      = 3 if symbol_config.hedge_mode else 0
    mode_resp = bybit_core.api_request(
        "POST", "/v5/position/switch-mode",
        params={
            "category": config.category,
            "symbol":   symbol,
            "mode":     mode,
        },
        signed=True,
    )
    # 110025 = "position mode not modified" — treat as OK
    if mode_resp.get("retCode") not in (0, 110025):
        logger.warning(
            "[%s] Position mode set returned: %s",
            symbol, mode_resp.get("retMsg"),
        )

    logger.info(
        "[%s] Init complete — tick=%.8f min_qty=%.8f "
        "leverage=%.1fx hedge=%s maker=%.4f%% taker=%.4f%%",
        symbol,
        symbol_config.tick_size,
        symbol_config.min_order_qty,
        symbol_config.leverage,
        symbol_config.hedge_mode,
        symbol_config.maker_fee * 100,
        symbol_config.taker_fee * 100,
    )
    return True


def validate_and_set_leverage_for_symbol(
    symbol_config: SymbolConfig,
) -> bool:
    symbol  = symbol_config.symbol
    lev_str = str(int(symbol_config.leverage))
    resp    = bybit_core.api_request(
        "POST", "/v5/position/set-leverage",
        params={
            "category":     config.category,
            "symbol":       symbol,
            "buyLeverage":  lev_str,
            "sellLeverage": lev_str,
        },
        signed=True,
    )
    # 110043 = leverage not modified (already set) — OK
    if resp.get("retCode") in (0, 110043):
        logger.info("[%s] Leverage confirmed at %sx", symbol, lev_str)
        return True
    logger.error("[%s] Set leverage failed: %s", symbol, resp.get("retMsg"))
    return False


# ═══════════════════════════════════════════════════════════════
# UTILITY / MATH HELPERS
# ═══════════════════════════════════════════════════════════════

def round_to_tick(price: float, tick_size: float) -> float:
    """Round *price* to the nearest valid tick."""
    if tick_size <= 0:
        return price
    # Derive decimal places from tick_size magnitude
    try:
        decimals = max(0, -int(f"{tick_size:e}".split('e')[1]))
    except (ValueError, IndexError):
        decimals = 8
    return round(round(price / tick_size) * tick_size, decimals)


def round_to_step(value: float, step: float) -> float:
    """Round *value* to the nearest valid quantity step."""
    if step <= 0:
        return value
    try:
        decimals = max(0, -int(f"{step:e}".split('e')[1]))
    except (ValueError, IndexError):
        decimals = 8
    return round(round(value / step) * step, decimals)


def calculate_pnl(
    side: str, entry_price: float, current_price: float, qty: float
) -> float:
    """Unrealised PnL for a position."""
    if qty <= 0:
        return 0.0
    if side == "Buy":
        return (current_price - entry_price) * qty
    return (entry_price - current_price) * qty


def calculate_breakeven_price(
    side:          str,
    entry_price:   float,
    entry_fee:     float,
    qty:           float,
    exit_fee_rate: float,
    tick_size:     float,
) -> float:
    """Net breakeven price after entry and exit fees."""
    if qty <= 0:
        return entry_price
    if side == "Buy":
        raw = entry_price + (entry_fee / qty) + entry_price * exit_fee_rate
    else:
        raw = entry_price - (entry_fee / qty) - entry_price * exit_fee_rate
    return round_to_tick(raw, tick_size)


def format_price(price: float, tick_size: float) -> str:
    """Format a price value as a string suitable for the Bybit API."""
    return str(round_to_tick(price, tick_size))


def format_qty(qty: float, qty_step: float) -> str:
    """Format a quantity value as a string suitable for the Bybit API."""
    return str(round_to_step(qty, qty_step))


# ═══════════════════════════════════════════════════════════════
# ACCOUNT / RISK MANAGEMENT
# ═══════════════════════════════════════════════════════════════

def get_account_balance() -> bool:
    """Fetch and update global account_info from the Bybit wallet endpoint."""
    if bybit_core is None:
        return False
    resp = bybit_core.api_request(
        "GET", "/v5/account/wallet-balance",
        params={"accountType": "UNIFIED"},
        signed=True,
    )
    if resp.get("retCode") != 0:
        logger.error("Wallet balance error: %s", resp.get("retMsg"))
        return False

    wallet_list = resp.get("result", {}).get("list", [])
    if not wallet_list:
        logger.error("Empty wallet list returned.")
        return False

    w = wallet_list[0]
    account_info.total_equity          = float(w.get("totalEquity",           0))
    account_info.available_balance     = float(w.get("totalAvailableBalance", 0))
    account_info.total_wallet_balance  = float(w.get("totalWalletBalance",    0))
    account_info.total_unrealized_pnl  = float(w.get("totalPerpUPL",         0))

    # Sum position values across all symbols
    pos_resp = bybit_core.api_request(
        "GET", "/v5/position/list",
        params={"category": config.category},
        signed=True,
    )
    account_info.total_position_value = 0.0
    if pos_resp.get("retCode") == 0:
        for pos in pos_resp.get("result", {}).get("list", []):
            if pos.get("size", "0") != "0":
                account_info.total_position_value += float(
                    pos.get("positionValue", 0)
                )

    if account_info.total_equity > 1e-9:
        account_info.margin_ratio = (
            account_info.total_position_value / account_info.total_equity
        )
    else:
        account_info.margin_ratio = 0.0

    if account_info.margin_ratio > 0.8:
        account_info.risk_level = "HIGH"
    elif account_info.margin_ratio > 0.5:
        account_info.risk_level = "MEDIUM"
    else:
        account_info.risk_level = "LOW"

    logger.info(
        "Balance — Equity: $%.2f | Available: $%.2f | uPnL: $%.2f "
        "| Margin: %.1f%% | Risk: %s",
        account_info.total_equity,
        account_info.available_balance,
        account_info.total_unrealized_pnl,
        account_info.margin_ratio * 100,
        account_info.risk_level,
    )
    return True


def update_daily_pnl() -> None:
    """Aggregate closed PnL for today across all configured symbols."""
    if bybit_core is None:
        return
    today_start_ms = int(
        datetime.now().replace(
            hour=0, minute=0, second=0, microsecond=0
        ).timestamp() * 1000
    )
    total_closed = 0.0
    for sym_cfg in config.symbols:
        resp = bybit_core.api_request(
            "GET", "/v5/position/closed-pnl",
            params={
                "category":  config.category,
                "symbol":    sym_cfg.symbol,
                "startTime": today_start_ms,
                "limit":     200,
            },
            signed=True,
        )
        if resp.get("retCode") == 0:
            for entry in resp.get("result", {}).get("list", []):
                total_closed += float(entry.get("closedPnl", 0))
        else:
            logger.warning(
                "[%s] Closed PnL fetch failed: %s",
                sym_cfg.symbol, resp.get("retMsg"),
            )
    account_info.daily_pnl = total_closed + account_info.total_unrealized_pnl
    logger.info(
        "Daily PnL — closed: $%.2f | open: $%.2f | total: $%.2f",
        total_closed,
        account_info.total_unrealized_pnl,
        account_info.daily_pnl,
    )


def check_risk_limits() -> bool:
    """Return False (and log) when any global risk limit is breached."""
    if account_info.daily_pnl < -config.max_daily_loss:
        logger.error(
            "Daily loss limit breached: $%.2f < -$%.2f",
            account_info.daily_pnl, config.max_daily_loss,
        )
        return False
    if account_info.margin_ratio > 0.95:
        logger.error(
            "Margin ratio critical: %.1f%%", account_info.margin_ratio * 100
        )
        return False
    if account_info.available_balance < 10.0:
        logger.warning(
            "Low available balance: $%.2f", account_info.available_balance
        )
    return True


def calculate_safe_position_size(
    symbol_config: SymbolConfig, current_price: float
) -> float:
    """
    Calculate a safe order quantity for *symbol_config* at *current_price*,
    respecting risk percentage, leverage, and minimum notional constraints.
    """
    symbol = symbol_config.symbol
    if account_info.total_equity <= 0 or current_price <= 0:
        logger.warning(
            "[%s] Cannot size position — invalid equity/price.", symbol
        )
        return symbol_config.min_order_qty

    # Risk-based ceiling
    target_value = (
        account_info.total_equity * (symbol_config.max_position_pct / 100.0)
    )
    qty_by_risk  = target_value / current_price

    # Leverage-based ceiling
    if symbol_config.leverage > 0:
        qty_by_leverage = (
            account_info.available_balance * symbol_config.leverage
        ) / current_price
    else:
        qty_by_leverage = qty_by_risk

    raw_qty = min(qty_by_risk, qty_by_leverage)

    # Enforce minimum notional
    if raw_qty * current_price < symbol_config.min_notional:
        raw_qty = symbol_config.min_notional / current_price

    # Enforce minimum order quantity
    raw_qty = max(raw_qty, symbol_config.min_order_qty)

    qty = round_to_step(raw_qty, symbol_config.qty_step)
    if qty <= 0:
        qty = symbol_config.min_order_qty

    logger.info(
        "[%s] Position size: %.8f "
        "(risk_ceil=%.8f lev_ceil=%.8f notional_min=%.2f)",
        symbol, qty, qty_by_risk, qty_by_leverage, symbol_config.min_notional,
    )
    return qty


# ═══════════════════════════════════════════════════════════════
# POSITION / ORDER HELPERS
# ═══════════════════════════════════════════════════════════════

def get_position_info_for_symbol(symbol: str) -> Optional[Position]:
    """Fetch the current open position for *symbol* from the REST API."""
    if bybit_core is None:
        return None
    resp = bybit_core.api_request(
        "GET", "/v5/position/list",
        params={"category": config.category, "symbol": symbol},
        signed=True,
    )
    if resp.get("retCode") != 0:
        logger.error(
            "[%s] Position list error: %s", symbol, resp.get("retMsg")
        )
        return None

    for p in resp.get("result", {}).get("list", []):
        if p.get("symbol") == symbol and float(p.get("size", 0)) != 0:
            return Position(
                position_idx    = int(p.get("positionIdx",    0)),
                side            = p.get("side",               ""),
                size            = float(p.get("size",         0)),
                avg_price       = float(p.get("avgPrice",     0)),
                leverage        = float(p.get("leverage",     1)),
                unrealised_pnl  = float(p.get("unrealisedPnl", 0)),
                liq_price       = float(p.get("liqPrice",     0)),
                take_profit     = p.get("takeProfit",          ""),
                stop_loss       = p.get("stopLoss",            ""),
                trailing_stop   = p.get("trailingStop",        ""),
                position_status = p.get("positionStatus",      "Normal"),
                created_time    = int(p.get("createdTime",     0)),
                updated_time    = int(p.get("updatedTime",     0)),
            )
    return None


def get_open_orders_for_symbol(symbol: str) -> bool:
    """Sync open orders for *symbol* with the REST API."""
    if bybit_core is None:
        return False
    resp = bybit_core.api_request(
        "GET", "/v5/order/realtime",
        params={
            "category": config.category,
            "symbol":   symbol,
            "openOnly": 1,
        },
        signed=True,
    )
    if resp.get("retCode") != 0:
        logger.error(
            "[%s] Open orders error: %s", symbol, resp.get("retMsg")
        )
        return False

    fresh_ids:   set = set()
    orders_list       = resp.get("result", {}).get("list", [])
    bucket            = open_orders_by_symbol.setdefault(symbol, {})

    for o in orders_list:
        oid = o["orderId"]
        fresh_ids.add(oid)
        bucket[oid] = OpenOrder(
            order_id      = oid,
            symbol        = o.get("symbol",      symbol),
            side          = o.get("side",         ""),
            order_type    = o.get("orderType",    ""),
            qty           = float(o.get("qty",    0)),
            price         = float(o.get("price",  0) or 0),
            order_status  = o.get("orderStatus",  ""),
            created_time  = int(o.get("createdTime", 0)),
            order_link_id = o.get("orderLinkId"),
        )

    # Prune stale entries
    for stale in set(bucket.keys()) - fresh_ids:
        del bucket[stale]

    logger.info("[%s] Open orders: %d", symbol, len(bucket))
    return True


def place_order(
    symbol_config:  SymbolConfig,
    side:           str,
    qty:            float,
    price:          float,
    order_type:     str           = "Limit",
    time_in_force:  str           = "GTC",
    tp:             Optional[float] = None,
    sl:             Optional[float] = None,
    trigger_price:  Optional[float] = None,
    trigger_by:     str           = "LastPrice",
    reason:         str           = "",
) -> Optional[str]:
    """
    Place an order for *symbol_config*.
    Returns orderId string on success, None on failure.
    """
    symbol   = symbol_config.symbol
    tick     = symbol_config.tick_size
    qty_step = symbol_config.qty_step

    # Quantity normalisation
    qty = max(qty, symbol_config.min_order_qty)
    qty = round_to_step(qty, qty_step)

    # Notional guard (not applicable for market orders)
    if price > 0 and order_type != "Market":
        if qty * price < symbol_config.min_notional:
            qty = round_to_step(
                symbol_config.min_notional / price, qty_step
            )

    if qty <= 0:
        logger.error("[%s] Quantity is zero — cannot place order.", symbol)
        return None

    # positionIdx: 0 = one-way, 1 = buy/hedge, 2 = sell/hedge
    position_idx = 0
    if symbol_config.hedge_mode:
        position_idx = 1 if side == "Buy" else 2

    params: dict = {
        "category":    config.category,
        "symbol":      symbol,
        "side":        side,
        "orderType":   order_type,
        "qty":         format_qty(qty, qty_step),
        "positionIdx": position_idx,
    }

    if order_type == "Market":
        params["timeInForce"] = "IOC"
    elif order_type == "Limit":
        if price <= 0:
            logger.error("[%s] Limit order needs a valid price.", symbol)
            return None
        params["price"]       = format_price(price, tick)
        params["timeInForce"] = time_in_force
    elif order_type == "Conditional":
        if not trigger_price:
            logger.error(
                "[%s] Conditional order needs trigger_price.", symbol
            )
            return None
        params["triggerPrice"]     = format_price(trigger_price, tick)
        params["triggerDirection"] = 1 if side == "Buy" else 2
        params["triggerBy"]        = trigger_by
        if price > 0:
            params["price"]        = format_price(price, tick)
        params["timeInForce"]      = time_in_force

    if tp is not None:
        params["takeProfit"]  = format_price(tp, tick)
        params["tpOrderType"] = "Market"
    if sl is not None:
        params["stopLoss"]    = format_price(sl, tick)
        params["slOrderType"] = "Market"
    if tp is not None or sl is not None:
        params["tpslMode"] = "Full"

    logger.info(
        "[%s] ORDER %s %s qty=%s price=%s tp=%s sl=%s | %s",
        symbol, order_type, side,
        params["qty"],
        params.get("price", "market"),
        params.get("takeProfit", "—"),
        params.get("stopLoss",   "—"),
        reason or "no reason",
    )

    resp = bybit_core.api_request(
        "POST", "/v5/order/create", params=params, signed=True
    )
    if resp.get("retCode") == 0:
        oid = resp.get("result", {}).get("orderId")
        logger.info("[%s] Order placed: %s", symbol, oid)
        return oid
    logger.error("[%s] Order failed: %s", symbol, resp.get("retMsg"))
    return None


def cancel_order(symbol: str, order_id: str) -> bool:
    """Cancel a single order by ID for *symbol*."""
    resp = bybit_core.api_request(
        "POST", "/v5/order/cancel",
        params={
            "category": config.category,
            "symbol":   symbol,
            "orderId":  order_id,
        },
        signed=True,
    )
    if resp.get("retCode") == 0:
        open_orders_by_symbol.get(symbol, {}).pop(order_id, None)
        logger.info("[%s] Cancelled order %s", symbol, order_id)
        return True
    logger.error(
        "[%s] Cancel %s failed: %s", symbol, order_id, resp.get("retMsg")
    )
    return False


def cancel_all_orders(symbol: str) -> bool:
    """Cancel every open order for *symbol*."""
    resp = bybit_core.api_request(
        "POST", "/v5/order/cancel-all",
        params={"category": config.category, "symbol": symbol},
        signed=True,
    )
    if resp.get("retCode") == 0:
        open_orders_by_symbol.get(symbol, {}).clear()
        logger.info("[%s] All orders cancelled.", symbol)
        return True
    logger.error(
        "[%s] Cancel-all failed: %s", symbol, resp.get("retMsg")
    )
    return False


def amend_order(
    symbol:    str,
    order_id:  str,
    new_price: Optional[float] = None,
    new_qty:   Optional[float] = None,
    tick_size: float           = 0.01,
) -> bool:
    """Amend price and/or quantity of an existing order."""
    if new_price is None and new_qty is None:
        return False
    params: dict = {
        "category": config.category,
        "symbol":   symbol,
        "orderId":  order_id,
    }
    if new_price is not None:
        params["price"] = format_price(new_price, tick_size)
    if new_qty is not None:
        params["qty"]   = str(new_qty)

    resp = bybit_core.api_request(
        "POST", "/v5/order/amend", params=params, signed=True
    )
    if resp.get("retCode") == 0:
        bucket = open_orders_by_symbol.get(symbol, {})
        if order_id in bucket:
            if new_price is not None:
                bucket[order_id].price = new_price
            if new_qty is not None:
                bucket[order_id].qty   = new_qty
        logger.info("[%s] Amended order %s", symbol, order_id)
        return True
    logger.error(
        "[%s] Amend %s failed: %s", symbol, order_id, resp.get("retMsg")
    )
    return False


def set_trading_stop_for_symbol(
    symbol:        str,
    position_idx:  int,
    take_profit:   Optional[float] = None,
    stop_loss:     Optional[float] = None,
    trailing_stop: Optional[float] = None,
    tick_size:     float           = 0.01,
) -> bool:
    """Update TP/SL/trailing-stop for an open position."""
    params: dict = {
        "category":    config.category,
        "symbol":      symbol,
        "tpslMode":    "Full",
        "positionIdx": position_idx,
    }
    if take_profit   is not None:
        params["takeProfit"]   = format_price(take_profit,   tick_size)
    if stop_loss     is not None:
        params["stopLoss"]     = format_price(stop_loss,     tick_size)
    if trailing_stop is not None:
        params["trailingStop"] = format_price(trailing_stop, tick_size)

    if len(params) == 4:    # nothing to update
        return False

    resp = bybit_core.api_request(
        "POST", "/v5/position/trading-stop", params=params, signed=True
    )
    if resp.get("retCode") == 0:
        logger.info(
            "[%s] Trading stop updated — TP=%s SL=%s TS=%s",
            symbol,
            params.get("takeProfit",   "—"),
            params.get("stopLoss",     "—"),
            params.get("trailingStop", "—"),
        )
        return True
    logger.error(
        "[%s] Trading stop failed: %s", symbol, resp.get("retMsg")
    )
    return False


def close_position(
    symbol_config: SymbolConfig,
    position:      Position,
    reason:        str,
) -> bool:
    """Close *position* with a market order."""
    symbol     = symbol_config.symbol
    close_side = "Sell" if position.side == "Buy" else "Buy"
    oid = place_order(
        symbol_config,
        side       = close_side,
        qty        = position.size,
        price      = 0.0,
        order_type = "Market",
        reason     = f"CLOSE: {reason}",
    )
    if oid:
        current_positions[symbol] = None
        return True
    return False


def set_disconnect_protection(time_window_sec: int = 60) -> bool:
    """Enable Bybit's disconnect-cancel-all protection."""
    resp = bybit_core.api_request(
        "POST", "/v5/order/disconnected-cancel-all",
        params={"timeWindow": time_window_sec},
        signed=True,
    )
    if resp.get("retCode") == 0:
        logger.info("Disconnect protection set: %ds", time_window_sec)
        return True
    logger.error("DCP failed: %s", resp.get("retMsg"))
    return False


# ═══════════════════════════════════════════════════════════════
# ORDER BOOK ANALYSIS
# ═══════════════════════════════════════════════════════════════

def _empty_metrics() -> OrderBookMetrics:
    return OrderBookMetrics()


def calculate_buying_pressure(
    bid_prices: List[float],
    bid_sizes:  List[float],
    ask_prices: List[float],
    ask_sizes:  List[float],
    spread:     float,
) -> float:
    """Compute weighted buying pressure score from orderbook data."""
    if not bid_prices or not ask_prices:
        return 0.0
    mid   = (bid_prices[0] + ask_prices[0]) / 2
    scale = max(spread * 2, 1e-6)

    weighted_bid = sum(
        b * math.exp(-(mid - bp) / scale)
        for b, bp in zip(bid_sizes, bid_prices)
    )
    ask_weakness = sum(
        a_s / (1 + (a_p - mid) / scale)
        for a_s, a_p in zip(ask_sizes, ask_prices)
    )
    total_bid = sum(bid_sizes)
    total_ask = sum(ask_sizes)
    return (weighted_bid / (total_bid + 1e-9)) / (
        (ask_weakness / (total_ask + 1e-9)) + 1e-9
    )


def calculate_selling_pressure(
    bid_prices: List[float],
    bid_sizes:  List[float],
    ask_prices: List[float],
    ask_sizes:  List[float],
    spread:     float,
) -> float:
    """Compute weighted selling pressure score from orderbook data."""
    if not bid_prices or not ask_prices:
        return 0.0
    mid   = (bid_prices[0] + ask_prices[0]) / 2
    scale = max(spread * 2, 1e-6)

    weighted_ask = sum(
        a_s * math.exp(-(a_p - mid) / scale)
        for a_s, a_p in zip(ask_sizes, ask_prices)
    )
    bid_weakness = sum(
        b_s / (1 + (mid - b_p) / scale)
        for b_s, b_p in zip(bid_sizes, bid_prices)
    )
    total_bid = sum(bid_sizes)
    total_ask = sum(ask_sizes)
    return (weighted_ask / (total_ask + 1e-9)) / (
        (bid_weakness / (total_bid + 1e-9)) + 1e-9
    )


def cluster_price_levels(
    levels:    List[float],
    threshold: float,
) -> List[float]:
    """Merge nearby price levels into clusters and return up to 3."""
    if not levels:
        return []
    levels   = sorted(levels)
    clusters: List[List[float]] = [[levels[0]]]
    for lv in levels[1:]:
        if lv - clusters[-1][-1] <= threshold:
            clusters[-1].append(lv)
        else:
            clusters.append([lv])
    means = [
        sum(c) / len(c) for c in clusters
    ]
    return sorted(means, reverse=True)[:3]


def detect_support_levels(
    bid_prices: np.ndarray,
    bid_sizes:  np.ndarray,
    tick_size:  float,
) -> List[float]:
    """Detect local-maxima in bid volume as support levels."""
    if bid_prices.size < 3:
        return []
    threshold = float(np.max(bid_sizes)) * 0.1
    levels = [
        float(bid_prices[i])
        for i in range(1, len(bid_sizes) - 1)
        if (
            float(bid_sizes[i]) > float(bid_sizes[i - 1])
            and float(bid_sizes[i]) > float(bid_sizes[i + 1])
            and float(bid_sizes[i]) > threshold
        )
    ]
    return cluster_price_levels(levels, tick_size * 5)


def detect_resistance_levels(
    ask_prices: np.ndarray,
    ask_sizes:  np.ndarray,
    tick_size:  float,
) -> List[float]:
    """Detect local-maxima in ask volume as resistance levels."""
    if ask_prices.size < 3:
        return []
    threshold = float(np.max(ask_sizes)) * 0.1
    levels = [
        float(ask_prices[i])
        for i in range(1, len(ask_sizes) - 1)
        if (
            float(ask_sizes[i]) > float(ask_sizes[i - 1])
            and float(ask_sizes[i]) > float(ask_sizes[i + 1])
            and float(ask_sizes[i]) > threshold
        )
    ]
    return cluster_price_levels(levels, tick_size * 5)


def calculate_order_book_skew(
    bid_prices: np.ndarray,
    bid_sizes:  np.ndarray,
    ask_prices: np.ndarray,
    ask_sizes:  np.ndarray,
) -> float:
    """
    Skew metric: positive = bids clustered near mid (bullish),
    negative = asks clustered near mid (bearish).
    """
    if bid_prices.size == 0 or ask_prices.size == 0:
        return 0.0
    mid = (float(bid_prices[0]) + float(ask_prices[0])) / 2
    if mid < 1e-9:
        return 0.0

    bid_vwap = float(
        np.sum(bid_prices * bid_sizes) / (np.sum(bid_sizes) + 1e-9)
    )
    ask_vwap = float(
        np.sum(ask_prices * ask_sizes) / (np.sum(ask_sizes) + 1e-9)
    )
    bd = (mid - bid_vwap) / mid
    ad = (ask_vwap - mid) / mid
    return (bd - ad) / (bd + ad + 1e-9)


def analyze_orderbook_advanced(
    bids:          List[List[str]],
    asks:          List[List[str]],
    symbol_config: SymbolConfig,
) -> OrderBookMetrics:
    """
    Full orderbook analysis — returns an OrderBookMetrics snapshot.
    Uses pure-Python lists for pressure calculations (no numpy dependency
    in the hot path) and numpy only where vectorised ops give clear value.
    """
    if not bids or not asks:
        return _empty_metrics()

    try:
        bp  = np.array([float(b[0]) for b in bids], dtype=float)
        bs  = np.array([float(b[1]) for b in bids], dtype=float)
        ap  = np.array([float(a[0]) for a in asks], dtype=float)
        as_ = np.array([float(a[1]) for a in asks], dtype=float)
    except (ValueError, IndexError) as exc:
        logger.error("Orderbook parse error: %s", exc)
        return _empty_metrics()

    bc = np.cumsum(bs)
    ac = np.cumsum(as_)

    n10_b = min(10,  len(bs));   bd10 = float(np.sum(bs[:n10_b]))
    n10_a = min(10,  len(as_));  ad10 = float(np.sum(as_[:n10_a]))
    n50_b = min(50,  len(bs));   bd50 = float(np.sum(bs[:n50_b]))
    n50_a = min(50,  len(as_));  ad50 = float(np.sum(as_[:n50_a]))
    bdt   = float(np.sum(bs))
    adt   = float(np.sum(as_))

    spread     = float(ap[0] - bp[0]) if ap[0] > bp[0] else 0.0
    spread_pct = (spread / float(bp[0]) * 100) if float(bp[0]) > 0 else 0.0

    # Convert to lists for pure-Python pressure functions
    bp_list  = bp.tolist()
    bs_list  = bs.tolist()
    ap_list  = ap.tolist()
    as_list  = as_.tolist()

    buy_p  = calculate_buying_pressure(bp_list, bs_list, ap_list, as_list, spread)
    sell_p = calculate_selling_pressure(bp_list, bs_list, ap_list, as_list, spread)
    mkt_p  = (buy_p - sell_p) / (buy_p + sell_p + 1e-9)

    tick = symbol_config.tick_size
    return OrderBookMetrics(
        bid_volume_profile   = list(zip(bp.tolist(), bc.tolist())),
        ask_volume_profile   = list(zip(ap.tolist(), ac.tolist())),
        bid_depth_10         = bd10,
        ask_depth_10         = ad10,
        bid_depth_50         = bd50,
        ask_depth_50         = ad50,
        bid_depth_total      = bdt,
        ask_depth_total      = adt,
        volume_imbalance     = (bdt - adt) / (bdt + adt + 1e-9),
        order_flow_imbalance = (bd10 - ad10) / (bd10 + ad10 + 1e-9),
        bid_ask_spread       = spread,
        spread_percentage    = spread_pct,
        buying_pressure      = buy_p,
        selling_pressure     = sell_p,
        market_pressure      = mkt_p,
        support_levels       = detect_support_levels(bp, bs, tick),
        resistance_levels    = detect_resistance_levels(ap, as_, tick),
        order_book_skew      = calculate_order_book_skew(bp, bs, ap, as_),
        liquidity_ratio      = bdt / (adt + 1e-9),
        market_depth_ratio   = (bd50 + ad50) / (bdt + adt + 1e-9),
    )


def analyze_orderbook_trends(history: deque) -> Dict[str, float]:
    """
    Fit linear trends over the last 10 orderbook snapshots.
    Returns slope coefficients for volume-imbalance, market-pressure,
    and spread-percentage.
    """
    default = {
        'volume_imbalance_trend': 0.0,
        'pressure_trend':         0.0,
        'spread_trend':           0.0,
    }
    if len(history) < 10:
        return default

    recent = list(history)[-10:]
    x      = np.arange(len(recent), dtype=float)
    try:
        return {
            'volume_imbalance_trend': float(
                np.polyfit(x, [m.volume_imbalance  for m in recent], 1)[0]
            ),
            'pressure_trend': float(
                np.polyfit(x, [m.market_pressure   for m in recent], 1)[0]
            ),
            'spread_trend': float(
                np.polyfit(x, [m.spread_percentage for m in recent], 1)[0]
            ),
        }
    except Exception as exc:
        logger.error("Trend calc error: %s", exc)
        return default


# ═══════════════════════════════════════════════════════════════
# SIGNAL GENERATION
# ═══════════════════════════════════════════════════════════════

def generate_advanced_signals(
    symbol_config: SymbolConfig,
    metrics:       OrderBookMetrics,
    current_price: float,
    trends:        Dict[str, float],
    position:      Optional[Position],
) -> List[TradingSignal]:
    """
    Evaluate orderbook metrics and trends to produce a ranked list
    of TradingSignal objects.
    """
    signals: List[TradingSignal] = []
    tick = symbol_config.tick_size

    has_long  = (
        position is not None
        and position.size > 0
        and position.side == "Buy"
    )
    has_short = (
        position is not None
        and position.size > 0
        and position.side == "Sell"
    )

    can_long  = not has_long  or symbol_config.hedge_mode
    can_short = not has_short or symbol_config.hedge_mode

    # ── Long entry ────────────────────────────────────────────
    if can_long:
        strength = 0.0
        reason   = ""
        if (
            metrics.market_pressure      > 0.3
            and metrics.volume_imbalance > 0.2
            and metrics.order_flow_imbalance > 0.15
        ):
            strength += 0.4
            reason   += f"Buy pressure={metrics.market_pressure:.2f}; "
        if (
            trends.get('pressure_trend', 0) > 0.005
            and metrics.market_pressure > 0.1
        ):
            strength += 0.3
            reason   += f"Uptrend={trends['pressure_trend']:.4f}; "
        if (
            metrics.support_levels
            and current_price < metrics.support_levels[0] + tick * 5
        ):
            strength += 0.2
            reason   += f"Near support={metrics.support_levels[0]:.4f}; "
        # Skew bonus
        if metrics.order_book_skew > 0.2:
            strength += 0.1
            reason   += f"Bullish skew={metrics.order_book_skew:.3f}; "

        if strength >= 0.7:
            sl_price = current_price * 0.992
            tp_price = current_price * 1.015
            signals.append(TradingSignal(
                signal_type   = "LONG_ENTRY",
                strength      = min(0.95, strength),
                reason        = reason,
                trigger_price = current_price,
                stop_loss     = sl_price,
                take_profit   = tp_price,
            ))

    # ── Short entry ───────────────────────────────────────────
    if can_short:
        strength = 0.0
        reason   = ""
        if (
            metrics.market_pressure       < -0.3
            and metrics.volume_imbalance  < -0.2
            and metrics.order_flow_imbalance < -0.15
        ):
            strength += 0.4
            reason   += f"Sell pressure={metrics.market_pressure:.2f}; "
        if (
            trends.get('pressure_trend', 0) < -0.005
            and metrics.market_pressure < -0.1
        ):
            strength += 0.3
            reason   += f"Downtrend={trends['pressure_trend']:.4f}; "
        if (
            metrics.resistance_levels
            and current_price > metrics.resistance_levels[0] - tick * 5
        ):
            strength += 0.2
            reason   += f"Near resistance={metrics.resistance_levels[0]:.4f}; "
        # Skew bonus
        if metrics.order_book_skew < -0.2:
            strength += 0.1
            reason   += f"Bearish skew={metrics.order_book_skew:.3f}; "

        if strength >= 0.7:
            sl_price = current_price * 1.008
            tp_price = current_price * 0.985
            signals.append(TradingSignal(
                signal_type   = "SHORT_ENTRY",
                strength      = min(0.95, strength),
                reason        = reason,
                trigger_price = current_price,
                stop_loss     = sl_price,
                take_profit   = tp_price,
            ))

    # ── Exit signals ──────────────────────────────────────────
    if position and position.size > 0:
        avg = position.avg_price
        pnl = position.unrealised_pnl

        pct = 0.0
        if avg > 1e-9:
            if position.side == "Buy":
                pct = (current_price - avg) / avg * 100
            else:
                pct = (avg - current_price) / avg * 100

        entry_fee  = avg * position.size * symbol_config.maker_fee
        exit_fee   = current_price * position.size * symbol_config.taker_fee
        net_profit = pnl - entry_fee - exit_fee

        if (
            pct >= symbol_config.profit_close_pct
            or net_profit >= config.min_profit
        ):
            exit_type = "EXIT_LONG" if position.side == "Buy" else "EXIT_SHORT"
            signals.append(TradingSignal(
                signal_type   = exit_type,
                strength      = 0.95,
                reason        = (
                    f"Profit target: {pct:.2f}% / ${net_profit:.2f}"
                ),
                trigger_price = current_price,
            ))

        # Hard stop — 10% equity drawdown on a single position
        if pnl < -(account_info.total_equity * 0.10):
            exit_type = "EXIT_LONG" if position.side == "Buy" else "EXIT_SHORT"
            signals.append(TradingSignal(
                signal_type   = exit_type,
                strength      = 1.0,
                reason        = f"Hard stop — position loss ${pnl:.2f}",
                trigger_price = current_price,
            ))

    return signals


# ═══════════════════════════════════════════════════════════════
# PROFIT / RISK CLOSE
# ═══════════════════════════════════════════════════════════════

def check_profit_close_conditions(
    symbol_config: SymbolConfig,
    position:      Position,
    current_price: float,
) -> bool:
    """
    Evaluate whether the current position for *symbol_config* should
    be closed based on profit target, daily loss, or margin ratio.
    Returns True if a close order was successfully placed.
    """
    if not position or position.size <= 0:
        return False

    avg = position.avg_price
    pnl = position.unrealised_pnl

    pct = 0.0
    if avg > 1e-9:
        if position.side == "Buy":
            pct = (current_price - avg) / avg * 100
        else:
            pct = (avg - current_price) / avg * 100

    entry_fee  = avg * position.size * symbol_config.maker_fee
    exit_fee   = current_price * position.size * symbol_config.taker_fee
    net_profit = pnl - entry_fee - exit_fee

    logger.info(
        "[%s] Pos %s %.8f@%.4f | pnl=$%.2f pct=%.2f%% net=$%.2f",
        symbol_config.symbol, position.side, position.size,
        avg, pnl, pct, net_profit,
    )

    reason = ""
    if pct >= symbol_config.profit_close_pct or net_profit >= config.min_profit:
        reason = f"Profit target ({pct:.2f}% / ${net_profit:.2f})"
    elif account_info.daily_pnl < -config.max_daily_loss:
        reason = f"Daily loss limit (${account_info.daily_pnl:.2f})"
    elif account_info.margin_ratio > 0.9:
        reason = f"Margin ratio critical ({account_info.margin_ratio:.1%})"

    if reason:
        return close_position(symbol_config, position, reason)
    return False


# ═══════════════════════════════════════════════════════════════
# WEBSOCKET HANDLERS
# ═══════════════════════════════════════════════════════════════

def handle_order_update(topic: str, order_data: list) -> None:
    """Route private order-stream updates to per-symbol state."""
    for order in order_data:
        sym    = order.get("symbol", "")
        if sym not in open_orders_by_symbol:
            continue
        oid    = order.get("orderId", "")
        status = order.get("orderStatus", "")
        bucket = open_orders_by_symbol[sym]
        if status in ("Filled", "Cancelled", "Rejected"):
            bucket.pop(oid, None)
            logger.info("[%s] Order %s → %s", sym, oid, status)
        elif oid in bucket:
            bucket[oid].order_status = status


def handle_position_update(topic: str, position_data: list) -> None:
    """Route private position-stream updates to per-symbol state."""
    for p in position_data:
        sym  = p.get("symbol", "")
        size = float(p.get("size", 0))
        if sym not in current_positions:
            continue
        if size == 0:
            current_positions[sym] = None
            logger.info("[%s] Position closed (WS update).", sym)
        else:
            current_positions[sym] = Position(
                position_idx    = int(p.get("positionIdx",     0)),
                side            = p.get("side",                ""),
                size            = size,
                avg_price       = float(p.get("avgPrice",      0)),
                leverage        = float(p.get("leverage",      1)),
                unrealised_pnl  = float(p.get("unrealisedPnl", 0)),
                liq_price       = float(p.get("liqPrice",      0)),
                take_profit     = p.get("takeProfit",           ""),
                stop_loss       = p.get("stopLoss",             ""),
                trailing_stop   = p.get("trailingStop",         ""),
                position_status = p.get("positionStatus",       "Normal"),
                created_time    = int(p.get("createdTime",      0)),
                updated_time    = int(p.get("updatedTime",      0)),
            )
            pos = current_positions[sym]
            logger.info(
                "[%s] Position update: %s %.8f @ %.4f (pnl $%.2f)",
                sym, pos.side, pos.size, pos.avg_price, pos.unrealised_pnl,
            )


def setup_websocket_streams() -> None:
    """
    Subscribe to private order/position streams.
    Public orderbook data is fetched via REST in the strategy loop
    to keep latency deterministic.
    """
    if not WEBSOCKET_AVAILABLE:
        logger.warning("WebSocket unavailable — skipping WS setup.")
        return
    if bybit_core is None:
        logger.error("BybitCore not initialised — cannot setup WS.")
        return

    ws = bybit_core.websocket_manager
    ws.register_handler("order",    handle_order_update)
    ws.register_handler("position", handle_position_update)

    private_topics = ["order", "position"]
    ws.connect_private(private_topics)
    logger.info("Private WS subscribed: %s", private_topics)


# ═══════════════════════════════════════════════════════════════
# EMERGENCY SHUTDOWN
# ═══════════════════════════════════════════════════════════════

def emergency_shutdown(reason: str = "Emergency") -> None:
    """
    Halt all trading activity immediately:
    1. Set the global stop flag.
    2. Cancel every open order for every symbol.
    3. Close every open position.
    4. Disconnect WebSockets.
    """
    global emergency_stop
    with _emergency_lock:
        if emergency_stop:
            return
        emergency_stop = True

    logger.critical("EMERGENCY SHUTDOWN: %s", reason)

    if bybit_core:
        for sym_cfg in config.symbols:
            sym = sym_cfg.symbol
            try:
                cancel_all_orders(sym)
            except Exception as exc:
                logger.error(
                    "[%s] Emergency cancel failed: %s", sym, exc
                )
            try:
                pos = get_position_info_for_symbol(sym)
                if pos and pos.size > 0:
                    close_position(sym_cfg, pos, f"Emergency: {reason}")
            except Exception as exc:
                logger.error(
                    "[%s] Emergency close failed: %s", sym, exc
                )

        try:
            bybit_core.websocket_manager.disconnect()
        except Exception as exc:
            logger.error("WS disconnect error during shutdown: %s", exc)

    logger.critical("Emergency shutdown complete.")


# ═══════════════════════════════════════════════════════════════
# PER-SYMBOL STRATEGY LOOP
# ═══════════════════════════════════════════════════════════════

def run_strategy_for_symbol(symbol_config: SymbolConfig) -> None:
    """
    Execute one iteration of the trading strategy for a single symbol.
    Called from the main loop sequentially for each configured symbol.
    """
    symbol = symbol_config.symbol

    # ── Price check ───────────────────────────────────────────
    current_price = current_prices.get(symbol, 0.0)
    if current_price <= 0:
        logger.warning("[%s] No valid price — skipping.", symbol)
        return

    # ── Sync position and orders ──────────────────────────────
    if current_positions.get(symbol) is None:
        current_positions[symbol] = get_position_info_for_symbol(symbol)

    if not open_orders_by_symbol.get(symbol):
        get_open_orders_for_symbol(symbol)

    # ── Orderbook fetch ───────────────────────────────────────
    ob_resp = bybit_core.api_request(
        "GET", "/v5/market/orderbook",
        params={
            "category": config.category,
            "symbol":   symbol,
            "limit":    symbol_config.orderbook_depth,
        },
    )
    if ob_resp.get("retCode") != 0 or not ob_resp.get("result"):
        logger.error(
            "[%s] Orderbook fetch failed: %s", symbol, ob_resp.get("retMsg")
        )
        return

    bids = ob_resp["result"].get("b", [])
    asks = ob_resp["result"].get("a", [])
    if not bids or not asks:
        logger.warning("[%s] Empty orderbook.", symbol)
        return

    # Update mid-price from live orderbook
    mid = (float(bids[0][0]) + float(asks[0][0])) / 2
    if mid > 0:
        current_prices[symbol] = mid
        current_price          = mid

    # ── Analysis ──────────────────────────────────────────────
    metrics = analyze_orderbook_advanced(bids, asks, symbol_config)
    orderbook_history_by_symbol[symbol].append(metrics)
    trends  = analyze_orderbook_trends(orderbook_history_by_symbol[symbol])

    logger.info(
        "[%s] P=%.4f spread=%.4f(%.4f%%) "
        "bidD10=%.2f askD10=%.2f pressure=%.3f skew=%.3f orders=%d",
        symbol, current_price,
        metrics.bid_ask_spread, metrics.spread_percentage,
        metrics.bid_depth_10, metrics.ask_depth_10,
        metrics.market_pressure, metrics.order_book_skew,
        len(open_orders_by_symbol.get(symbol, {})),
    )

    pos = current_positions.get(symbol)

    # ── Exit checks ───────────────────────────────────────────
    if pos and pos.size > 0:
        if check_profit_close_conditions(symbol_config, pos, current_price):
            return  # position closed — done for this iteration

        # Trailing stop update when in profit
        if pos.unrealised_pnl > 0:
            if pos.side == "Buy":
                trail_price = current_price * 0.99
                cur_trail   = float(pos.trailing_stop) if pos.trailing_stop else 0.0
                if trail_price > cur_trail:
                    set_trading_stop_for_symbol(
                        symbol, pos.position_idx,
                        trailing_stop=trail_price,
                        tick_size=symbol_config.tick_size,
                    )
            else:
                trail_price = current_price * 1.01
                cur_trail   = float(pos.trailing_stop) if pos.trailing_stop else 0.0
                if cur_trail == 0.0 or trail_price < cur_trail:
                    set_trading_stop_for_symbol(
                        symbol, pos.position_idx,
                        trailing_stop=trail_price,
                        tick_size=symbol_config.tick_size,
                    )

    # ── Entry logic ───────────────────────────────────────────
    if not config.auto_trade:
        return

    open_count = len(open_orders_by_symbol.get(symbol, {}))
    if open_count > 0:
        return  # already have pending orders

    signals = generate_advanced_signals(
        symbol_config, metrics, current_price, trends, pos
    )
    if not signals:
        return

    signals.sort(key=lambda s: s.strength, reverse=True)
    best = signals[0]

    # Handle exits first
    if best.signal_type in ("EXIT_LONG", "EXIT_SHORT"):
        if pos and pos.size > 0:
            close_position(symbol_config, pos, best.reason)
        return

    # Entry orders
    safe_qty = calculate_safe_position_size(symbol_config, current_price)
    if safe_qty < symbol_config.min_order_qty:
        logger.warning(
            "[%s] Safe qty %.8f < min %.8f — skip.",
            symbol, safe_qty, symbol_config.min_order_qty,
        )
        return

    if best.signal_type == "LONG_ENTRY":
        place_order(
            symbol_config,
            side       = "Buy",
            qty        = safe_qty,
            price      = best.trigger_price,
            order_type = "Limit",
            tp         = best.take_profit,
            sl         = best.stop_loss,
            reason     = best.reason,
        )
    elif best.signal_type == "SHORT_ENTRY":
        place_order(
            symbol_config,
            side       = "Sell",
            qty        = safe_qty,
            price      = best.trigger_price,
            order_type = "Limit",
            tp         = best.take_profit,
            sl         = best.stop_loss,
            reason     = best.reason,
        )


# ═══════════════════════════════════════════════════════════════
# MAIN TRADING LOOP
# ═══════════════════════════════════════════════════════════════

def run_trading_bot() -> None:
    """
    Main orchestration loop.
    Periodically refreshes global account data and risk limits, then
    runs the per-symbol strategy for every configured symbol.
    """
    logger.info("═══ Multi-Symbol Trading Bot Starting ═══")
    logger.info(
        "Symbols : %s", ", ".join(s.symbol for s in config.symbols)
    )
    logger.info(
        "Config  : interval=%ds auto_trade=%s tor=%s "
        "max_daily_loss=$%.2f min_profit=$%.2f",
        config.interval, config.auto_trade, config.use_tor,
        config.max_daily_loss, config.min_profit,
    )

    set_disconnect_protection(120)
    setup_websocket_streams()

    last_balance_fetch:   float = 0.0
    last_daily_pnl_fetch: float = 0.0
    BALANCE_INTERVAL:   float = 30.0
    DAILY_PNL_INTERVAL: float = 300.0

    try:
        while not emergency_stop:
            loop_start = time.time()

            # ── Global data refresh ───────────────────────────
            if loop_start - last_balance_fetch > BALANCE_INTERVAL:
                if not get_account_balance():
                    logger.error("Balance fetch failed — retrying next cycle.")
                    time.sleep(config.interval)
                    continue
                last_balance_fetch = time.time()

            if loop_start - last_daily_pnl_fetch > DAILY_PNL_INTERVAL:
                update_daily_pnl()
                last_daily_pnl_fetch = time.time()

            if not check_risk_limits():
                emergency_shutdown("Global risk limit breached")
                break

            # ── Price refresh for all symbols ─────────────────
            for sym_cfg in config.symbols:
                sym = sym_cfg.symbol
                tick_resp = bybit_core.api_request(
                    "GET", "/v5/market/orderbook",
                    params={
                        "category": config.category,
                        "symbol":   sym,
                        "limit":    1,
                    },
                )
                if tick_resp.get("retCode") == 0:
                    result = tick_resp.get("result", {})
                    bids   = result.get("b", [])
                    asks   = result.get("a", [])
                    if bids and asks:
                        current_prices[sym] = (
                            float(bids[0][0]) + float(asks[0][0])
                        ) / 2

            # ── Per-symbol strategy ───────────────────────────
            for sym_cfg in config.symbols:
                if emergency_stop:
                    break
                try:
                    run_strategy_for_symbol(sym_cfg)
                except Exception as exc:
                    logger.error(
                        "[%s] Strategy error: %s",
                        sym_cfg.symbol, exc, exc_info=True,
                    )
                    pos = current_positions.get(sym_cfg.symbol)
                    if pos and pos.size > 0:
                        try:
                            close_position(
                                sym_cfg, pos,
                                "Strategy exception safety close",
                            )
                        except Exception as close_exc:
                            logger.error(
                                "[%s] Safety close failed: %s",
                                sym_cfg.symbol, close_exc,
                            )

            elapsed    = time.time() - loop_start
            sleep_time = max(0.0, config.interval - elapsed)
            time.sleep(sleep_time)

    except KeyboardInterrupt:
        logger.info("Keyboard interrupt — shutting down gracefully.")
    except Exception as exc:
        logger.critical(
            "Unhandled main loop exception: %s", exc, exc_info=True
        )
        emergency_shutdown(f"Unhandled exception: {exc}")
    finally:
        emergency_shutdown("Bot stopping")
        save_config()
        logger.info("═══ Trading Bot Stopped ═══")


# ═══════════════════════════════════════════════════════════════
# CLI ARGUMENT PARSER
# ═══════════════════════════════════════════════════════════════

def _parse_args() -> argparse.Namespace:
    """Parse CLI arguments."""
    parser = argparse.ArgumentParser(
        description=(
            "Advanced Multi-Symbol Scalper with All Features Integrated"
        ),
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    parser.add_argument(
        "--interval", type=int, default=5,
        help="Monitoring interval for each symbol's strategy loop (s)",
    )
    parser.add_argument(
        "--auto-trade", action="store_true",
        help="Execute trades automatically",
    )
    parser.add_argument(
        "--qty", type=float, default=0.2,
        help="Base quantity to trade",
    )
    parser.add_argument(
        "--symbols", type=str, default="",
        help="Comma-separated list of symbols (e.g., ETHUSDT,BTCUSDT)",
    )
    parser.add_argument(
        "--min-profit", type=float, default=2.0,
        help="Global minimum profit target in USD to close any position",
    )
    parser.add_argument(
        "--use-conditional", action="store_true", default=True,
        help="Default to use conditional orders for entry",
    )
    parser.add_argument(
        "--leverage", type=float, default=5.0,
        help="Default position leverage for symbols",
    )
    parser.add_argument(
        "--hedge-mode", action="store_true", default=False,
        help="Default hedge mode for symbols",
    )
    parser.add_argument(
        "--orderbook-depth", type=int, default=200,
        help="Default orderbook depth for analysis",
    )
    parser.add_argument(
        "--max-daily-loss", type=float, default=50.0,
        help="Default maximum daily loss limit in USD",
    )
    parser.add_argument(
        "--max-position-pct", type=float, default=10.0,
        help="Default max position size as %% of balance",
    )
    parser.add_argument(
        "--profit-close-pct", type=float, default=1.5,
        help="Default profit percentage to close position",
    )
    parser.add_argument(
        "--use-tor", action="store_true", default=False,
        help="Route traffic through Tor network",
    )
    parser.add_argument(
        "--tor-socks-port", type=int, default=9050,
        help="Tor SOCKS port",
    )
    parser.add_argument(
        "--api-key", type=str,
        default=os.environ.get("BYBIT_API_KEY"),
        help="Bybit API Key (or BYBIT_API_KEY env var)",
    )
    parser.add_argument(
        "--api-secret", type=str,
        default=os.environ.get("BYBIT_API_SECRET"),
        help="Bybit API Secret (or BYBIT_API_SECRET env var)",
    )
    parser.add_argument(
        "--debug", action="store_true",
        help="Enable debug logging",
    )
    return parser.parse_args()


# ═══════════════════════════════════════════════════════════════
# AIChat TOOL ENTRY POINT
# ═══════════════════════════════════════════════════════════════

def run(**kwargs) -> str:
    """
    Entry point for AIChat tool system.
    Receives keyword arguments and returns a result string.
    """
    # Build argv list from kwargs
    argv: List[str] = []

    if kwargs.get("interval") is not None:
        argv.extend(["--interval", str(kwargs["interval"])])
    if str(kwargs.get("auto_trade", "")).lower() == "true":
        argv.append("--auto-trade")
    if kwargs.get("qty") is not None:
        argv.extend(["--qty", str(kwargs["qty"])])
    if kwargs.get("symbols"):
        argv.extend(["--symbols", str(kwargs["symbols"])])
    if kwargs.get("min_profit") is not None:
        argv.extend(["--min-profit", str(kwargs["min_profit"])])
    if kwargs.get("leverage") is not None:
        argv.extend(["--leverage", str(kwargs["leverage"])])
    if str(kwargs.get("hedge_mode", "")).lower() == "true":
        argv.append("--hedge-mode")
    if kwargs.get("orderbook_depth") is not None:
        argv.extend(["--orderbook-depth", str(kwargs["orderbook_depth"])])
    if kwargs.get("max_daily_loss") is not None:
        argv.extend(["--max-daily-loss", str(kwargs["max_daily_loss"])])
    if kwargs.get("max_position_pct") is not None:
        argv.extend(["--max-position-pct", str(kwargs["max_position_pct"])])
    if kwargs.get("profit_close_pct") is not None:
        argv.extend(["--profit-close-pct", str(kwargs["profit_close_pct"])])
    if str(kwargs.get("use_conditional", "")).lower() == "true":
        argv.append("--use-conditional")
    if str(kwargs.get("use_tor", "")).lower() == "true":
        argv.append("--use-tor")
    if kwargs.get("tor_socks_port") is not None:
        argv.extend(["--tor-socks-port", str(kwargs["tor_socks_port"])])
    if kwargs.get("api_key"):
        argv.extend(["--api-key", str(kwargs["api_key"])])
    if kwargs.get("api_secret"):
        argv.extend(["--api-secret", str(kwargs["api_secret"])])
    if str(kwargs.get("debug", "")).lower() == "true":
        argv.append("--debug")

    old_argv = sys.argv
    sys.argv  = ["bybit-scalper"] + argv

    try:
        args = _parse_args()

        if args.debug:
            logging.getLogger().setLevel(logging.DEBUG)
            logger.debug("Debug logging active.")

        load_config()

        config.interval         = args.interval
        config.auto_trade       = args.auto_trade
        config.base_qty         = args.qty
        config.min_profit       = args.min_profit
        config.use_tor          = args.use_tor
        config.tor_socks_port   = args.tor_socks_port
        config.max_daily_loss   = args.max_daily_loss
        config.max_position_pct = args.max_position_pct

        if args.api_key:    config.api_key    = args.api_key
        if args.api_secret: config.api_secret = args.api_secret

        cli_symbols: List[SymbolConfig] = []
        if args.symbols:
            for raw in args.symbols.split(','):
                name = raw.strip().upper()
                if not name:
                    continue
                sc = SymbolConfig(
                    symbol           = name,
                    leverage         = args.leverage,
                    hedge_mode       = args.hedge_mode,
                    orderbook_depth  = args.orderbook_depth,
                    max_daily_loss   = args.max_daily_loss,
                    max_position_pct = args.max_position_pct,
                    profit_close_pct = args.profit_close_pct,
                    use_conditional  = args.use_conditional,
                )
                cli_symbols.append(sc)

        if cli_symbols:
            config.symbols = cli_symbols
        elif not config.symbols:
            msg = "No symbols configured. Use --symbols or config file."
            logger.error(msg)
            return f"Error: {msg}"

        if config.base_qty <= 0:
            msg = "--qty must be positive."
            logger.error(msg)
            return f"Error: {msg}"

        if not config.api_key or not config.api_secret:
            logger.warning(
                "No API credentials — read-only / simulation mode."
            )

        initialize_networking(
            config.use_tor, config.tor_socks_port,
            config.api_key, config.api_secret,
        )

        ready_symbols: List[SymbolConfig] = []
        for sc in config.symbols:
            if initialize_trading_environment_for_symbol(sc):
                ready_symbols.append(sc)
            else:
                logger.error("[%s] Init failed — excluded.", sc.symbol)

        if not ready_symbols:
            msg = "No symbols ready after initialisation."
            logger.error(msg)
            return f"Error: {msg}"

        config.symbols = ready_symbols
        initialize_all_symbol_states()
        run_trading_bot()
        return "Trading bot stopped."

    except KeyboardInterrupt:
        return "Trading bot stopped by user."
    except Exception as exc:
        logger.error("Tool execution error: %s", exc, exc_info=True)
        return f"Error: {exc}"
    finally:
        sys.argv = old_argv


# ═══════════════════════════════════════════════════════════════
# DIRECT EXECUTION ENTRY POINT
# ═══════════════════════════════════════════════════════════════

if __name__ == "__main__":
    args = _parse_args()

    if args.debug:
        logging.getLogger().setLevel(logging.DEBUG)
        logger.debug("Debug logging active.")

    load_config()

    config.interval         = args.interval
    config.auto_trade       = args.auto_trade
    config.base_qty         = args.qty
    config.min_profit       = args.min_profit
    config.use_tor          = args.use_tor
    config.tor_socks_port   = args.tor_socks_port
    config.max_daily_loss   = args.max_daily_loss
    config.max_position_pct = args.max_position_pct

    if args.api_key:    config.api_key    = args.api_key
    if args.api_secret: config.api_secret = args.api_secret

    cli_symbols: List[SymbolConfig] = []
    if args.symbols:
        for raw in args.symbols.split(','):
            name = raw.strip().upper()
            if not name:
                continue
            sc = SymbolConfig(
                symbol           = name,
                leverage         = args.leverage,
                hedge_mode       = args.hedge_mode,
                orderbook_depth  = args.orderbook_depth,
                max_daily_loss   = args.max_daily_loss,
                max_position_pct = args.max_position_pct,
                profit_close_pct = args.profit_close_pct,
                use_conditional  = args.use_conditional,
            )
            cli_symbols.append(sc)

    if cli_symbols:
        config.symbols = cli_symbols
    elif not config.symbols:
        logger.error("No symbols configured. Use --symbols or config file.")
        sys.exit(1)

    if config.base_qty <= 0:
        logger.error("--qty must be positive.")
        sys.exit(1)

    if not config.api_key or not config.api_secret:
        logger.warning(
            "No API credentials — running in read-only / simulation mode."
        )

    initialize_networking(
        config.use_tor, config.tor_socks_port,
        config.api_key, config.api_secret,
    )

    ready_symbols: List[SymbolConfig] = []
    for sc in config.symbols:
        if initialize_trading_environment_for_symbol(sc):
            ready_symbols.append(sc)
        else:
            logger.error("[%s] Init failed — excluded.", sc.symbol)

    if not ready_symbols:
        logger.error("No symbols ready after initialisation. Exiting.")
        sys.exit(1)

    config.symbols = ready_symbols
    initialize_all_symbol_states()
    run_trading_bot()
