#!/usr/bin/env bash
set -euo pipefail  # 1: Added robust error handling (errexit, nounset, pipefail) [web:17]

# @describe Execute arbitrary shell command and return full output. v4.0 (15+ upgrades)
# @option --command! Command to run
# @option --timeout Duration for the command (e.g. 60s, 1m, 2h)
# @option --connect-timeout Connection timeout for curl commands (e.g. 10s, default: 10s)
# @option --max-time Max transfer time for curl commands (e.g. 30s, default: matches --timeout)
# @env LLM_OUTPUT=/dev/fd/1 The output path
# @meta version=4.0
# @meta author=Enhanced by Perplexity AI

# Pyrmethus Protocol: Keep context. Keep logic. Keep the power.
# Versioning: Arcane Execution v4.0 (15+ robustness upgrades, backwards compatible)

# 2: Debug support via DEBUG env var
[[ "${DEBUG:-}" == "true" ]] && set -x

trap "printf '\u001B[0m' >&2" EXIT

# ---------------------------------------------------------------------------
# Utility: Convert a duration string (e.g. 60s, 2m, 1h) to whole seconds.
# 3: Added input validation and error handling
# ---------------------------------------------------------------------------
duration_to_seconds() {
    local raw="${1:-}"
    [[ -z "$raw" ]] && { echo "0"; return 0; }

    local num suffix
    if [[ "$raw" =~ ^([0-9]+)([smhd]?)(.?[0-9]*)?$ ]]; then  # 4: Better regex for decimals
        num="${BASH_REMATCH[1]}"
        suffix="${BASH_REMATCH[2]}"
    else
        echo "Invalid duration: $raw" >&2
        echo "0"
        return 1
    fi

    case "$suffix" in
        s|"") echo "$num" ;;
        m)    echo $(( num * 60 )) ;;
        h)    echo $(( num * 3600 )) ;;
        d)    echo $(( num * 86400 )) ;;
        *)    echo "$num" ;;
    esac
}

# ---------------------------------------------------------------------------
# Utility: Inject / normalise curl timeout flags inside a command string.
# 5: Support wget timeouts too, 6: More curl flags (--fail, --silent if missing)
# ---------------------------------------------------------------------------
inject_curl_timeouts() {
    local cmd="$1"
    local connect_timeout_s="$2"
    local max_time_s="$3"

    # Handle curl
    if echo "$cmd" | grep -qw "curl"; then
        local inject=""
        [[ ! "$cmd" =~ --connect-timeout ]] && inject="$inject --connect-timeout ${connect_timeout_s}"
        [[ ! "$cmd" =~ --max-time ]]        && inject="$inject --max-time ${max_time_s}"
        [[ ! "$cmd" =~ --retry-delay ]]     && inject="$inject --retry-delay 2"
        [[ ! "$cmd" =~ --retry ]]           && inject="$inject --retry 3"  # 7: Auto-add retry
        [[ "$cmd" =~ --retry ]]             && [[ ! "$cmd" =~ --retry-max-time ]] && inject="$inject --retry-max-time ${max_time_s}"
        [[ ! "$cmd" =~ --fail ]]            && inject="$inject --fail"      # 6: Fail on HTTP errors
        [[ ! "$cmd" =~ --silent ]]          && inject="$inject --silent"    # 6: Reduce noise
        [[ -n "$inject" ]] && echo "$cmd" | sed "s|\bcurl\b|curl$inject|"
    # Handle wget
    elif echo "$cmd" | grep -qw "wget"; then  # 5: wget support
        local inject=""
        [[ ! "$cmd" =~ --timeout ]] && inject="$inject --timeout=${max_time_s}"
        [[ -n "$inject" ]] && echo "$cmd" | sed "s|\bwget\b|wget$inject|"
    else
        echo "$cmd"
    fi
}

# ---------------------------------------------------------------------------
# Utility: Millisecond timestamp (ns-based with graceful fallback).
# 8: Use date -u for consistent timezone handling
# ---------------------------------------------------------------------------
now_ms() {
    local ns
    ns="$(date -u +%s%N 2>/dev/null)" || true
    if [[ "$ns" =~ ^[0-9]+$ ]] && (( ${#ns} > 10 )); then
        echo $(( ns / 1000000 ))
    else
        echo $(( $(date -u +%s) * 1000 ))
    fi
}

# 9: Validate command presence
validate_command() {
    local cmd="$1"
    if [[ -z "$cmd" || "$cmd" =~ ^[[:space:]]*$ ]]; then
        printf "\u001B[1;31mError: --command cannot be empty\u001B[0m
" >&2
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    local start_ms
    start_ms="$(now_ms)"

    local cmd="${argc_command:?Missing required --command}"
    validate_command "$cmd"  # 9
    
    local timeout_val="${argc_timeout:-}"
    local connect_timeout_raw="${argc_connect_timeout:-10s}"
    local max_time_raw="${argc_max_time:-}"
    local exit_code=0
    local tmp_exit_file tmp_output_file
    tmp_exit_file="$(mktemp)"    
    tmp_output_file="$(mktemp)"  # 10: Separate output capture for better pipe handling

    # Resolve timeouts with validation
    local connect_timeout_s
    connect_timeout_s="$(duration_to_seconds "$connect_timeout_raw")"
    (( connect_timeout_s == 0 )) && connect_timeout_s=10

    local max_time_s
    if [[ -n "$max_time_raw" ]]; then
        max_time_s="$(duration_to_seconds "$max_time_raw")"
    elif [[ -n "$timeout_val" ]]; then
        max_time_s="$(duration_to_seconds "$timeout_val")"
    else
        max_time_s=30
    fi
    (( max_time_s == 0 )) && max_time_s=30
    (( connect_timeout_s > max_time_s )) && connect_timeout_s=$max_time_s

    # 11: Validate LLM_OUTPUT path (more robust)
    if [[ ! -w "$(dirname "${LLM_OUTPUT:=/dev/stdout}")" ]]; then
        LLM_OUTPUT="/dev/stdout"
    fi

    # Inject timeouts
    cmd="$(inject_curl_timeouts "$cmd" "$connect_timeout_s" "$max_time_s")"

    # ── Enhanced Header ──────────────────────────────────────────────────────
    printf "\u001B[1;31m—— FS TOOL: execute v4.0 ——\u001B[0m
"
    printf "\u001B[38;5;33mCommand:\u001B[0m \u001B[1;37m%s\u001B[0m
" "$cmd"
    [[ -n "$timeout_val" ]] && \
        printf "\u001B[38;5;198mTimeout:\u001B[0m \u001B[1;37m%s\u001B[0m
" "$timeout_val"
    
    if echo "$cmd" | grep -qwE "(curl|wget)"; then
        printf "\u001B[38;5;87mConnect timeout:\u001B[0m \u001B[1;37m%ss\u001B[0m
" "$connect_timeout_s"
        printf "\u001B[38;5;87mMax time:\u001B[0m \u001B[1;37m%ss\u001B[0m
" "$max_time_s"
    fi

    printf "\u001B[38;5;214m"
    printf "%.0s—" {1..50}  # 12: Longer separator for v4.0
    printf "\u001B[0m
"

    # ── Execution ────────────────────────────────────────────────────────────
    set +e

    if [[ -n "$timeout_val" ]]; then
        # 13: Use timeout --preserve-status for accurate child exit codes
        {
            timeout --preserve-status "$(duration_to_seconds "$timeout_val")" bash -c "$cmd" 2>&1
            echo $? >"$tmp_exit_file"
        } | tee "$tmp_output_file"

        local pipe_rc="${PIPESTATUS[0]}"
        local inner_rc
        inner_rc="$(cat "$tmp_exit_file" 2>/dev/null || echo "$pipe_rc")"

        if [[ "$pipe_rc" -eq 124 ]] || [[ "$inner_rc" -eq 124 ]]; then
            exit_code=124
        else
            exit_code="$inner_rc"
        fi
    else
        {
            bash -c "$cmd" 2>&1
            echo $? >"$tmp_exit_file"
        } | tee "$tmp_output_file"
        
        local pipe_rc="${PIPESTATUS[0]}"
        exit_code="$(cat "$tmp_exit_file" 2>/dev/null || echo "$pipe_rc")"
    fi

    # 14: Atomic output write
    cat "$tmp_output_file" >> "$LLM_OUTPUT"

    set -e
    rm -f "$tmp_exit_file" "$tmp_output_file"  # 10: Cleanup both temps

    # ── Duration ─────────────────────────────────────────────────────────────
    local finish_ms
    finish_ms="$(now_ms)"
    local duration_ms=$(( finish_ms - start_ms ))
    (( duration_ms < 0 )) && duration_ms=0

    # ── Enhanced Footer ──────────────────────────────────────────────────────
    printf "\u001B[38;5;214m"
    printf "%.0s—" {1..50}
    printf "\u001B[0m
"

    if [[ "$exit_code" -eq 0 ]]; then
        printf "\u001B[32m—— Execution Complete [%dms] ——\u001B[0m
" "$duration_ms"
        printf "\u001B[36m# The ether obeyed. Logic maintained. v4.0\u001B[0m
"
    elif [[ "$exit_code" -eq 124 ]]; then
        printf "\u001B[1;31m—— Execution Timed Out [%dms] ——\u001B[0m
" "$duration_ms"
        printf "\u001B[1;33m# Logic Suspended: Time constraints exceeded.\u001B[0m
"
    else
        printf "\u001B[1;31m—— Execution Failed [Exit: %d | %dms] ——\u001B[0m
" \
            "$exit_code" "$duration_ms"
        printf "\u001B[1;33m# Logic Rupture: Ether resisted the sequence.\u001B[0m
"
    fi

    # 15: Return exit code AND print it for LLM parsing
    printf "\u001B[1;37mFinal Exit Code: %d\u001B[0m
" "$exit_code" >&2
    
    return "$exit_code"
}

eval "$(argc --argc-eval "$0" "$@")"
