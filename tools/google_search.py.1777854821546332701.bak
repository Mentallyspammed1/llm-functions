#!/usr/bin/env python3
"""
google_search.py - Google Search Tool with Content Crawling

A powerful tool for performing Google searches and optionally crawling content
from search result URLs. Uses multiple search methods for better reliability.
"""

import json
import sys
import argparse
import logging
import time
import urllib.request
import urllib.error
import urllib.parse
from typing import List, Dict, Any, Optional, Literal
from html.parser import HTMLParser
from dataclasses import dataclass, asdict

try:
    import requests
    from bs4 import BeautifulSoup
    HAS_REQUESTS = True
except ImportError:
    HAS_REQUESTS = False

try:
    from googlesearch import search
    HAS_GOOGLESEARCH = True
except ImportError:
    HAS_GOOGLESEARCH = False


@dataclass
class SearchResult:
    """Represents a single search result with optional crawled content."""
    position: int
    url: str
    title: str = ""
    snippet: str = ""
    content: str = ""
    error: str = ""


class ContentExtractor(HTMLParser):
    """HTML parser to extract clean text content from web pages."""
    
    def __init__(self, max_length: int = 3000):
        super().__init__()
        self.max_length = max_length
        self.content = []
        self.in_script = False
        self.in_style = False
        self.current_length = 0
    
    def handle_starttag(self, tag, attrs):
        if tag in ['script', 'style']:
            self.in_script = True
        elif tag in ['p', 'div', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'li', 'span']:
            if self.content and self.content[-1] not in [' ', '\n']:
                self.content.append(' ')
    
    def handle_endtag(self, tag):
        if tag in ['script', 'style']:
            self.in_script = False
        elif tag in ['p', 'div', 'li']:
            if self.content and self.content[-1] != '\n':
                self.content.append('\n')
    
    def handle_data(self, data):
        if not self.in_script and data.strip():
            words = data.split()
            for word in words:
                if self.current_length >= self.max_length:
                    return
                self.content.append(word)
                self.current_length += len(word) + 1
    
    def get_text(self) -> str:
        """Return cleaned text content."""
        text = ' '.join(self.content)
        text = ' '.join(text.split())
        return text


def setup_logging(verbose: bool = False) -> None:
    """Setup logging configuration."""
    level = logging.DEBUG if verbose else logging.WARNING
    logging.basicConfig(
        level=level,
        format='%(asctime)s - %(levelname)s - %(message)s',
        datefmt='%Y-%m-%d %H:%M:%S'
    )


def validate_query(query: str) -> None:
    """Validate search query."""
    if not query or not query.strip():
        raise ValueError("Search query cannot be empty")


def crawl_url(url: str, timeout: int = 10, max_length: int = 3000, verbose: bool = False) -> str:
    """
    Crawl a URL and extract text content.
    
    Args:
        url: URL to crawl
        timeout: Request timeout in seconds
        max_length: Maximum content length to extract
        verbose: Enable verbose logging
        
    Returns:
        Extracted text content or error message
    """
    logger = logging.getLogger(__name__)
    
    try:
        headers = {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36'
        }
        
        req = urllib.request.Request(url, headers=headers)
        
        if verbose:
            logger.debug(f"Crawling URL: {url}")
        
        with urllib.request.urlopen(req, timeout=timeout) as response:
            content_type = response.headers.get('content-type', '').lower()
            
            if 'text/html' not in content_type:
                return f"[Non-HTML content: {content_type}]"
            
            html_content = response.read().decode('utf-8', errors='ignore')
            
            parser = ContentExtractor(max_length)
            parser.feed(html_content)
            
            extracted_text = parser.get_text()
            
            if verbose:
                logger.debug(f"Extracted {len(extracted_text)} characters from {url}")
            
            return extracted_text
            
    except urllib.error.HTTPError as e:
        error_msg = f"HTTP {e.code}: {e.reason}"
        if verbose:
            logger.warning(f"Failed to crawl {url}: {error_msg}")
        return f"[Error: {error_msg}]"
    except urllib.error.URLError as e:
        error_msg = f"URL Error: {e.reason}"
        if verbose:
            logger.warning(f"Failed to crawl {url}: {error_msg}")
        return f"[Error: {error_msg}]"
    except Exception as e:
        error_msg = f"Unexpected error: {str(e)}"
        if verbose:
            logger.warning(f"Failed to crawl {url}: {error_msg}")
        return f"[Error: {error_msg}]"


def fallback_google_search(query: str, num_results: int = 10, timeout: int = 10) -> List[str]:
    """
    Fallback Google search using requests and BeautifulSoup.
    
    Args:
        query: Search query
        num_results: Number of results to return
        timeout: Request timeout
        
    Returns:
        List of URLs
    """
    if not HAS_REQUESTS:
        raise ImportError("requests library is required for fallback search")
    
    headers = {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36'
    }
    
    encoded_query = urllib.parse.quote_plus(query)
    search_url = f"https://www.google.com/search?q={encoded_query}"
    
    try:
        response = requests.get(search_url, headers=headers, timeout=timeout)
        response.raise_for_status()
        
        soup = BeautifulSoup(response.text, 'html.parser')
        
        results = []
        for link in soup.find_all('a'):
            href = link.get('href', '')
            if href.startswith('/url?q='):
                url = href.split('/url?q=')[1].split('&')[0]
                if url.startswith('http') and 'google.com' not in url:
                    results.append(url)
                    if len(results) >= num_results:
                        break
        
        return results
        
    except Exception as e:
        raise RuntimeError(f"Fallback search failed: {str(e)}")


def search_google(
    query: str,
    num_results: int = 10,
    lang: str = "en",
    region: str = "us",
    safe_search: str = "moderate",
    pause: float = 2.0,
    crawl: bool = False,
    content_length: int = 3000,
    timeout: int = 10,
    verbose: bool = False
) -> List[Dict[str, Any]]:
    """
    Perform Google search and optionally crawl content from results.
    
    Args:
        query: Search query string
        num_results: Number of results to return
        lang: Language code
        region: Region code
        safe_search: Safe search level
        pause: Pause between requests
        crawl: Whether to crawl content from URLs
        content_length: Maximum content length per page
        timeout: Request timeout for crawling
        verbose: Enable verbose logging
        
    Returns:
        List of search result dictionaries with optional content
    """
    setup_logging(verbose)
    logger = logging.getLogger(__name__)
    
    validate_query(query)
    
    results = []
    search_urls = []
    
    # Try different search methods
    if HAS_GOOGLESEARCH:
        try:
            logger.info("Using googlesearch-python library")
            safe_mapping = {
                "off": "off",
                "moderate": "moderate", 
                "strict": "strict"
            }
            safe_level = safe_mapping.get(safe_search.lower(), "moderate")
            
            search_urls = list(search(
                query,
                num_results=num_results,
                lang=lang,
                safe=safe_level,
                pause=pause
            ))
        except Exception as e:
            logger.warning(f"googlesearch-python failed: {e}")
    
    # Fallback to custom implementation
    if not search_urls and HAS_REQUESTS:
        try:
            logger.info("Using fallback search method")
            search_urls = fallback_google_search(query, num_results, timeout)
        except Exception as e:
            logger.warning(f"Fallback search failed: {e}")
    
    if not search_urls:
        raise RuntimeError("All search methods failed. Please check your internet connection and try again.")
    
    logger.info(f"Found {len(search_urls)} results")
    
    for i, url in enumerate(search_urls[:num_results], 1):
        result = SearchResult(
            position=i,
            url=url,
            title="",
            snippet="",
            content=""
        )
        
        if crawl:
            if verbose:
                logger.info(f"Crawling result {i}: {url}")
            
            result.content = crawl_url(
                url, 
                timeout=timeout, 
                max_length=content_length,
                verbose=verbose
            )
            
            if i < len(search_urls):
                time.sleep(pause)
        
        results.append(asdict(result))
        logger.debug(f"Result {i}: {url}")
    
    return results


def run(
    query: str,
    limit: int = 10,
    lang: str = "en",
    region: str = "us",
    safe_search: Literal["off", "moderate", "strict"] = "moderate",
    pause: float = 2.0,
    crawl: bool = False,
    content_length: int = 3000,
    timeout: int = 10,
    verbose: bool = False
):
    """Perform a Google search and optionally crawl content from result URLs.

    Args:
        query: The search query to use.
        limit: Maximum number of results to return (default: 10).
        lang: Language code for the search (default: "en").
        region: Region code for the search (default: "us").
        safe_search: Safe search level ("off", "moderate", "strict") (default: "moderate").
        pause: Pause in seconds between requests when crawling (default: 2.0).
        crawl: If true, fetch and extract content from result URLs (default: False).
        content_length: Maximum content length to extract per page in characters (default: 3000).
        timeout: Request timeout in seconds for crawling (default: 10).
        verbose: If true, enable verbose logging output (default: False).
    """
    try:
        results = search_google(
            query=query,
            num_results=limit,
            lang=lang,
            region=region,
            safe_search=safe_search,
            pause=pause,
            crawl=crawl,
            content_length=content_length,
            timeout=timeout,
            verbose=verbose
        )
        return results
    except (ValueError, RuntimeError) as e:
        raise e
    except Exception as e:
        raise RuntimeError(f"An unexpected error occurred: {e}") from e
