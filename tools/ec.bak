#!/usr/bin/env bash
set -e

# @describe Execute arbitrary shell command and return full output.
# @option --command! Command to run
# @option --timeout Duration for the command (e.g. 60s, 1m, 2h)
# @option --connect-timeout Connection timeout for curl commands (e.g. 10s, default: 10s)
# @option --max-time Max transfer time for curl commands (e.g. 30s, default: matches --timeout)
# @env LLM_OUTPUT=/dev/fd/1 The output path

# Pyrmethus Protocol: Keep context. Keep logic. Keep the power.
# Versioning: Wizard Upgrade - Arcane Execution v3.3 (curl-aware + robust pipe handling)

trap "printf '\u001B[0m' >&2" EXIT

# ---------------------------------------------------------------------------
# Utility: Convert a duration string (e.g. 60s, 2m, 1h) to whole seconds.
# Returns the numeric value; suffixless values are passed through as-is.
# ---------------------------------------------------------------------------
duration_to_seconds() {
    local raw="${1:-}"
    [[ -z "$raw" ]] && { echo "0"; return; }

    local num suffix
    # Extract leading digits and optional suffix
    if [[ "$raw" =~ ^([0-9]+)([smhd]?)$ ]]; then
        num="${BASH_REMATCH[1]}"
        suffix="${BASH_REMATCH[2]}"
    else
        # Not a recognized pattern — return as-is and let caller handle it
        echo "$raw"
        return
    fi

    case "$suffix" in
        s|"") echo "$num" ;;
        m)    echo $(( num * 60 )) ;;
        h)    echo $(( num * 3600 )) ;;
        d)    echo $(( num * 86400 )) ;;
        *)    echo "$num" ;;
    esac
}

# ---------------------------------------------------------------------------
# Utility: Inject / normalise curl timeout flags inside a command string.
#
#   --connect-timeout N   – abort if connection not established within N s
#   --max-time N          – abort entire transfer after N s
#   --retry-delay 2       – wait 2 s between retries (safe default)
#   --retry-max-time N    – cap total retry wall-clock time
# The function only modifies the command when the string contains "curl".
# Existing user-supplied --connect-timeout / --max-time flags are preserved.
# ---------------------------------------------------------------------------
inject_curl_timeouts() {
    local cmd="$1"
    local connect_timeout_s="$2"   # already in seconds
    local max_time_s="$3"          # already in seconds

    # Nothing to do if curl is not in the command
    if ! echo "$cmd" | grep -qw "curl"; then
        echo "$cmd"
        return
    fi

    local inject=""

    # Only add --connect-timeout if the user has not already set it
    if ! echo "$cmd" | grep -q -- "--connect-timeout"; then
        inject="$inject --connect-timeout ${connect_timeout_s}"
    fi

    # Only add --max-time if the user has not already set it
    if ! echo "$cmd" | grep -q -- "--max-time"; then
        inject="$inject --max-time ${max_time_s}"
    fi

    # Only add --retry-delay if the user has not already set it
    if ! echo "$cmd" | grep -q -- "--retry-delay"; then
        inject="$inject --retry-delay 2"
    fi

    # Only add --retry-max-time if the user has not already set it and
    # a --retry flag is present (no point adding it otherwise)
    if echo "$cmd" | grep -q -- "--retry" && \
       ! echo "$cmd" | grep -q -- "--retry-max-time"; then
        inject="$inject --retry-max-time ${max_time_s}"
    fi

    if [[ -z "$inject" ]]; then
        echo "$cmd"
        return
    fi

    # Insert the injected flags immediately after the first "curl" token
    echo "$cmd" | sed "s|\\bcurl\\b|curl${inject}|"
}

# ---------------------------------------------------------------------------
# Utility: Millisecond timestamp (ns-based with graceful fallback).
# ---------------------------------------------------------------------------
now_ms() {
    local ns
    ns="$(date +%s%N 2>/dev/null)" || true
    if [[ "$ns" =~ ^[0-9]+$ ]] && (( ${#ns} > 10 )); then
        echo $(( ns / 1000000 ))
    else
        # Fallback: seconds-only precision
        echo $(( $(date +%s) * 1000 ))
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    local start_ms
    start_ms="$(now_ms)"

    local cmd="${argc_command:?Missing required --command}"
    local timeout_val="${argc_timeout:-}"
    local connect_timeout_raw="${argc_connect_timeout:-10s}"
    local max_time_raw="${argc_max_time:-}"
    local exit_code=0
    local tmp_exit_file
    tmp_exit_file="$(mktemp)"   # reliable exit-code capture across pipes

    # Resolve connect-timeout to seconds (integer)
    local connect_timeout_s
    connect_timeout_s="$(duration_to_seconds "$connect_timeout_raw")"
    (( connect_timeout_s == 0 )) && connect_timeout_s=10

    # Resolve max-time: default to timeout value if not explicitly set,
    # or fall back to 30 s when neither is provided.
    local max_time_s
    if [[ -n "$max_time_raw" ]]; then
        max_time_s="$(duration_to_seconds "$max_time_raw")"
    elif [[ -n "$timeout_val" ]]; then
        max_time_s="$(duration_to_seconds "$timeout_val")"
    else
        max_time_s=30
    fi
    (( max_time_s == 0 )) && max_time_s=30

    # Ensure connect-timeout never exceeds max-time
    (( connect_timeout_s > max_time_s )) && connect_timeout_s=$max_time_s

    # Verify write access to the output path; fallback to stdout if protected
    if [[ ! -w "$(dirname "$LLM_OUTPUT")" ]]; then
        LLM_OUTPUT="/dev/stdout"
    fi

    # Inject curl timeouts into the command string when applicable
    cmd="$(inject_curl_timeouts "$cmd" "$connect_timeout_s" "$max_time_s")"

    # ── Header ──────────────────────────────────────────────────────────────
    printf "\u001B[1;31m—— FS TOOL: execute ——\u001B[0m\n"
    printf "\u001B[38;5;33mCommand:\u001B[0m \u001B[1;37m%s\u001B[0m\n" "$cmd"
    [[ -n "$timeout_val" ]] && \
        printf "\u001B[38;5;198mTimeout:\u001B[0m \u001B[1;37m%s\u001B[0m\n" "$timeout_val"

    # Show curl-specific timeout info only when relevant
    if echo "$cmd" | grep -qw "curl"; then
        printf "\u001B[38;5;87mCurl connect-timeout:\u001B[0m \u001B[1;37m%ss\u001B[0m\n" \
            "$connect_timeout_s"
        printf "\u001B[38;5;87mCurl max-time:\u001B[0m \u001B[1;37m%ss\u001B[0m\n" \
            "$max_time_s"
    fi

    printf "\u001B[38;5;214m"
    printf "%.0s—" {1..42}
    printf "\u001B[0m\n"

    # ── Execution ────────────────────────────────────────────────────────────
    set +e

    if [[ -n "$timeout_val" ]]; then
        # -------------------------------------------------------------------
        # Hard-limit execution via timeout(1).
        # The subshell writes its own exit code to a temp file so we can
        # retrieve it reliably after tee consumes the pipe.
        # -------------------------------------------------------------------
        {
            timeout "$timeout_val" bash -c "$cmd"
            echo $? >"$tmp_exit_file"
        } 2>&1 | tee -a "$LLM_OUTPUT"

        # tee exit code (pipe) takes precedence for timeout detection
        local pipe_rc="${PIPESTATUS[0]}"
        local inner_rc
        inner_rc="$(cat "$tmp_exit_file" 2>/dev/null || echo "$pipe_rc")"

        # timeout(1) returns 124 when the child was killed; propagate that.
        if [[ "$pipe_rc" -eq 124 ]] || [[ "$inner_rc" -eq 124 ]]; then
            exit_code=124
        else
            exit_code="$inner_rc"
        fi
    else
        # -------------------------------------------------------------------
        # No timeout: run via bash -c for consistent behaviour with the
        # timeout branch (avoids eval security concerns on arbitrary input).
        # -------------------------------------------------------------------
        {
            bash -c "$cmd"
            echo $? >"$tmp_exit_file"
        } 2>&1 | tee -a "$LLM_OUTPUT"

        local pipe_rc="${PIPESTATUS[0]}"
        exit_code="$(cat "$tmp_exit_file" 2>/dev/null || echo "$pipe_rc")"
    fi

    set -e

    # Clean up temp file
    rm -f "$tmp_exit_file"

    # ── Duration ─────────────────────────────────────────────────────────────
    local finish_ms
    finish_ms="$(now_ms)"
    local duration_ms=$(( finish_ms - start_ms ))
    (( duration_ms < 0 )) && duration_ms=0

    # ── Footer ───────────────────────────────────────────────────────────────
    printf "\u001B[38;5;214m"
    printf "%.0s—" {1..42}
    printf "\u001B[0m\n"

    if [[ "$exit_code" -eq 0 ]]; then
        printf "\u001B[32m—— Execution Complete [%dms] ——\u001B[0m\n" "$duration_ms"
        printf "\u001B[36m# The ether obeyed. Logic maintained.\u001B[0m\n"
    elif [[ "$exit_code" -eq 124 ]]; then
        printf "\u001B[1;31m—— Execution Timed Out [%dms] ——\u001B[0m\n" "$duration_ms"
        printf "\u001B[1;33m# Logic Suspended: Command exceeded time constraints.\u001B[0m\n"
    else
        printf "\u001B[1;31m—— Execution Failed [Exit Code: %d | %dms] ——\u001B[0m\n" \
            "$exit_code" "$duration_ms"
        printf "\u001B[1;33m# Logic Rupture: The ether resisted the sequence.\u001B[0m\n"
    fi

    return "$exit_code"
}

eval "$(argc --argc-eval "$0" "$@")"
